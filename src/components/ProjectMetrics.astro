---
interface Metric {
  label: string;
  labelEn?: string;
  value: string;
}

interface Props {
  metrics?: Metric[];
}

const { metrics } = Astro.props;
---

{metrics && metrics.length > 0 && (
  <div class="project-metrics">
    <h3 class="project-metrics__title" data-i18n-pt="Metricas do Projeto" data-i18n-en="Project Metrics">Metricas do Projeto</h3>
    <div class="project-metrics__grid">
      {metrics.map(m => (
        <div class="project-metric">
          <span class="project-metric__value">{m.value}</span>
          <span class="project-metric__label"
            data-i18n-pt={m.label}
            data-i18n-en={m.labelEn || m.label}
          >{m.label}</span>
        </div>
      ))}
    </div>
    {metrics.length >= 3 && (
      <div class="project-metrics__chart">
        <svg width="100%" height="60" viewBox="0 0 300 60" aria-hidden="true" style="max-width:300px;">
          {metrics.slice(0, 5).map((m, i) => {
            const numVal = parseFloat(m.value.replace(/[^0-9.]/g, '')) || 0;
            const maxW = 260;
            const barW = Math.min(maxW, (numVal / 100) * maxW);
            const y = i * 12;
            return (
              <g>
                <rect x="0" y={y} width={maxW} height="8" rx="2" fill="var(--border-light)" />
                <rect x="0" y={y} width={Math.max(4, barW)} height="8" rx="2" fill="var(--accent)" opacity="0.7" />
              </g>
            );
          })}
        </svg>
      </div>
    )}
  </div>
)}
