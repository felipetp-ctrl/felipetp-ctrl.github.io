---
interface Props {
  username: string;
}
const { username } = Astro.props;
---

<section class="heatmap-section" id="activity">
  <div class="container--wide">
    <div class="section-header">
      <span class="section-title">Atividade de commits</span>
      <span class="section-count">últimos 12 meses · GitHub</span>
    </div>

    <div id="heatmap-container">
      <div class="heatmap-error skeleton" style="height: 80px;"></div>
    </div>

    <div class="heatmap-stats" id="heatmap-stats" style="display:none">
      <div class="heatmap-stat">
        <span class="heatmap-stat__value" id="stat-total">—</span>
        <span class="heatmap-stat__label">Commits totais</span>
      </div>
      <div class="heatmap-stat">
        <span class="heatmap-stat__value" id="stat-streak">—</span>
        <span class="heatmap-stat__label">Maior sequência</span>
      </div>
      <div class="heatmap-stat">
        <span class="heatmap-stat__value" id="stat-peak">—</span>
        <span class="heatmap-stat__label">Pico diário</span>
      </div>
      <div class="heatmap-stat">
        <span class="heatmap-stat__value" id="stat-active">—</span>
        <span class="heatmap-stat__label">Dias ativos</span>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ username }}>
  (async function buildHeatmap() {
    const container = document.getElementById('heatmap-container');
    const statsEl = document.getElementById('heatmap-stats');

    // Build 52-week × 7-day date grid (Sun→Sat)
    function buildDateGrid() {
      const today = new Date();
      const days = [];
      // Go back exactly 371 days to start on a Sunday
      const start = new Date(today);
      start.setDate(start.getDate() - 371);
      // Advance to next Sunday
      start.setDate(start.getDate() + (7 - start.getDay()) % 7);

      const cur = new Date(start);
      while (cur <= today) {
        days.push(cur.toISOString().slice(0, 10));
        cur.setDate(cur.getDate() + 1);
      }
      return days;
    }

    function toLevel(count) {
      if (count === 0) return 0;
      if (count <= 2) return 1;
      if (count <= 5) return 2;
      if (count <= 10) return 3;
      return 4;
    }

    function computeStats(contributions) {
      const counts = Object.values(contributions);
      const total = counts.reduce((a, b) => a + b, 0);
      const peak = Math.max(...counts, 0);
      const activeDays = counts.filter(c => c > 0).length;

      // Longest streak of consecutive days
      const sortedDates = Object.keys(contributions).sort();
      let maxStreak = 0, curStreak = 0;
      for (let i = 0; i < sortedDates.length; i++) {
        if (contributions[sortedDates[i]] > 0) {
          curStreak++;
          maxStreak = Math.max(maxStreak, curStreak);
        } else {
          curStreak = 0;
        }
      }
      return { total, peak, activeDays, maxStreak };
    }

    function renderHeatmap(contributions) {
      const days = buildDateGrid();
      const allWeeks = [];
      for (let i = 0; i < days.length; i += 7) {
        allWeeks.push(days.slice(i, i + 7));
      }

      // Month labels
      const monthNames = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
      const monthPositions = [];
      let lastMonth = -1;
      allWeeks.forEach((week, wi) => {
        const d = new Date(week[0]);
        const m = d.getMonth();
        if (m !== lastMonth) {
          monthPositions.push({ wi, label: monthNames[m] });
          lastMonth = m;
        }
      });

      const totalCols = allWeeks.length;
      const cellSize = 11;
      const gap = 2;

      // Build month row
      const monthRow = document.createElement('div');
      monthRow.className = 'heatmap-months';
      monthRow.style.cssText = `display:flex; margin-bottom:4px; font-family:var(--font-mono); font-size:0.65rem; color:var(--text-light); position:relative; height:14px;`;

      monthPositions.forEach((mp, idx) => {
        const span = document.createElement('span');
        const leftPx = mp.wi * (cellSize + gap);
        span.textContent = mp.label;
        span.style.cssText = `position:absolute; left:${leftPx}px;`;
        monthRow.appendChild(span);
      });

      // Day labels
      const dayLabels = ['Dom','','Ter','','Qui','','Sáb'];
      const dayLabelEl = document.createElement('div');
      dayLabelEl.style.cssText = `display:grid; grid-template-rows:repeat(7,${cellSize}px); gap:${gap}px; margin-right:6px; font-family:var(--font-mono); font-size:0.6rem; color:var(--text-light); line-height:${cellSize}px;`;
      dayLabels.forEach(d => {
        const s = document.createElement('span');
        s.textContent = d;
        s.style.height = `${cellSize}px`;
        dayLabelEl.appendChild(s);
      });

      // Grid
      const grid = document.createElement('div');
      grid.className = 'heatmap-grid';
      grid.style.cssText = `display:grid; grid-template-rows:repeat(7,${cellSize}px); grid-auto-flow:column; grid-auto-columns:${cellSize}px; gap:${gap}px;`;

      allWeeks.forEach(week => {
        week.forEach(dateStr => {
          const cell = document.createElement('div');
          const count = contributions[dateStr] || 0;
          const level = toLevel(count);
          cell.className = 'heatmap-cell';
          if (level > 0) cell.dataset.level = String(level);
          cell.title = `${dateStr}: ${count} commit${count !== 1 ? 's' : ''}`;
          grid.appendChild(cell);
        });
      });

      // Legend
      const legend = document.createElement('div');
      legend.className = 'heatmap-legend';
      legend.innerHTML = `
        <span>Menos</span>
        <div class="heatmap-legend__cells">
          ${[0,1,2,3,4].map(l => `<div class="heatmap-legend__cell heatmap-cell" ${l > 0 ? `data-level="${l}"` : ''} style="width:${cellSize}px;height:${cellSize}px;border-radius:2px;"></div>`).join('')}
        </div>
        <span>Mais</span>
      `;

      const wrapper = document.createElement('div');
      wrapper.className = 'heatmap-wrapper';

      const innerFlex = document.createElement('div');
      innerFlex.style.cssText = `display:inline-flex; align-items:flex-start; gap:0;`;

      const rightCol = document.createElement('div');
      rightCol.appendChild(monthRow);
      rightCol.appendChild(grid);

      innerFlex.appendChild(dayLabelEl);
      innerFlex.appendChild(rightCol);
      wrapper.appendChild(innerFlex);

      container.innerHTML = '';
      container.appendChild(wrapper);
      container.appendChild(legend);

      // Stats
      const { total, peak, activeDays, maxStreak } = computeStats(contributions);
      document.getElementById('stat-total').textContent = total.toLocaleString('pt-BR');
      document.getElementById('stat-streak').textContent = `${maxStreak}d`;
      document.getElementById('stat-peak').textContent = String(peak);
      document.getElementById('stat-active').textContent = String(activeDays);
      statsEl.style.display = 'flex';
    }

    // Try fetching from the public contributions API
    async function fetchContributions() {
      try {
        const res = await fetch(
          `https://github-contributions-api.jogruber.de/v4/${username}?y=last`,
          { headers: { Accept: 'application/json' } }
        );
        if (!res.ok) throw new Error('API error');
        const data = await res.json();

        // The API returns { contributions: [ { date, count, level }] }
        const map = {};
        (data.contributions || []).forEach(d => {
          map[d.date] = d.count;
        });
        return map;
      } catch (_) {
        return null;
      }
    }

    // Fallback: GitHub Events API (only ~90 days, partial)
    async function fetchEventsAPI() {
      const map = {};
      try {
        for (let page = 1; page <= 3; page++) {
          const res = await fetch(
            `https://api.github.com/users/${username}/events/public?per_page=100&page=${page}`,
            { headers: { Accept: 'application/vnd.github+json' } }
          );
          if (!res.ok) break;
          const events = await res.json();
          if (!events.length) break;
          events.forEach(ev => {
            if (ev.type === 'PushEvent') {
              const date = ev.created_at.slice(0, 10);
              const commits = ev.payload?.commits?.length || 1;
              map[date] = (map[date] || 0) + commits;
            }
          });
        }
      } catch (_) {}
      return Object.keys(map).length > 0 ? map : null;
    }

    let contributions = await fetchContributions();
    if (!contributions) {
      contributions = await fetchEventsAPI();
    }

    if (contributions) {
      renderHeatmap(contributions);
    } else {
      container.innerHTML = `
        <div class="heatmap-error">
          Não foi possível carregar os dados de contribuição do GitHub.
          <br><small>Verifique se o perfil <strong>${username}</strong> é público.</small>
        </div>`;
    }
  })();
</script>
