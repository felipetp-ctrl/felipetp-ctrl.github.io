---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import ProjectMetrics from '../../../components/ProjectMetrics.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const locales = ['pt', 'en'] as const;
  const projects = await getCollection('projects');
  return projects.flatMap((project) =>
    locales.map((locale) => ({
      params: { locale, slug: project.id },
      props: { project, locale, allProjects: projects },
    })),
  );
}

const { project, locale, allProjects } = Astro.props as { project: any; locale: 'pt' | 'en'; allProjects: any[] };
const { Content } = await render(project);

// Related projects: same technologies, excluding current
const related = allProjects
  .filter(p => p.id !== project.id)
  .map(p => ({
    ...p,
    sharedCount: p.data.technologies.filter((t: string) => project.data.technologies.includes(t)).length,
  }))
  .filter(p => p.sharedCount > 0)
  .sort((a, b) => b.sharedCount - a.sharedCount)
  .slice(0, 3);

const isPdfPaper = project.data.paper && project.data.paper.endsWith('.pdf');

const statusLabels: Record<string, string> = {
  completed: 'Concluído',
  published: 'Publicado',
  'in-progress': 'Em andamento',
};

const statusLabelsEn: Record<string, string> = {
  completed: 'Completed',
  published: 'Published',
  'in-progress': 'In Progress',
};
---

<BaseLayout
  title={`${project.data.title} — Felipe Tomé Pereira | ML Research`}
  description={project.data.description}
  ogImage={`/og/${locale}/${project.id}.png`}
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    "name": project.data.title,
    "description": project.data.description,
    "author": { "@type": "Person", "name": "Felipe Tomé Pereira" },
    "programmingLanguage": project.data.technologies,
    "url": Astro.site ? new URL(`/${locale}/projects/${project.id}`, Astro.site).toString() : undefined,
    "codeRepository": project.data.github
  })} slot="head" />
  <div class="project-page">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Home', labelEn: 'Home', href: `/${locale}/` },
        { label: 'Projetos', labelEn: 'Projects', href: `/${locale}/#projects` },
        { label: project.data.title, labelEn: project.data.titleEn || project.data.title },
      ]} />
      <a href={`/${locale}/`} class="project-page__back" data-i18n="project.back">← Voltar ao portfólio</a>

      <!-- Metadata box -->
      <div class="project-page__meta">
        <div class="project-page__meta-grid">
          <div>
            <label>Status</label>
            <span
              class={`status status--${project.data.status}`}
              data-i18n-pt={statusLabels[project.data.status] ?? project.data.status}
              data-i18n-en={statusLabelsEn[project.data.status] ?? project.data.status}
            >
              {statusLabels[project.data.status] ?? project.data.status}
            </span>
          </div>
          <div>
            <label data-i18n="project.date-label">Data</label>
            <span style="font-family: var(--font-mono); font-size: 0.85rem;">
              {project.data.date}
            </span>
          </div>
          <div>
            <label data-i18n="project.technologies-label">Tecnologias</label>
            <div class="tags" style="margin-top:0.25rem">
              {project.data.technologies.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Title -->
      <h1 style="margin-bottom: 1rem; font-size: 1.6rem; line-height: 1.25;"
        transition:name={`project-title-${project.id}`}
        data-i18n-pt={project.data.title}
        data-i18n-en={project.data.titleEn || project.data.title}
      >
        {project.data.title}
      </h1>

      <!-- Abstract -->
      <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.8; margin-bottom: 1.25rem;"
        data-i18n-pt={project.data.description}
        data-i18n-en={project.data.descriptionEn || project.data.description}
      >
        {project.data.description}
      </p>

      <!-- Main result callout -->
      <div class="project-page__result">
        <strong data-i18n="project.main-result">Resultado Principal</strong>
        <span
          data-i18n-pt={project.data.mainResult}
          data-i18n-en={project.data.mainResultEn || project.data.mainResult}
        >{project.data.mainResult}</span>
      </div>

      <!-- Links -->
      <div class="project-page__links">
        {project.data.github && (
          <a href={project.data.github} target="_blank" rel="noopener" class="btn btn--outline" data-i18n="project.view-github">
            Ver no GitHub
          </a>
        )}
        {project.data.paper && (
          <a href={project.data.paper} target="_blank" rel="noopener" class="btn btn--primary" data-i18n="project.paper">
            Paper / Artigo
          </a>
        )}
        {project.data.demo && (
          <a href={project.data.demo} target="_blank" rel="noopener" class="btn btn--ghost" data-i18n="project.demo">
            Demo ao vivo
          </a>
        )}
      </div>
    </div>

    <!-- Markdown body -->
    <div class="container">
      <div class="project-page__body">
        <Content />

        <!-- Share buttons -->
        <ShareButtons url={Astro.site ? new URL(`/${locale}/projects/${project.id}`, Astro.site).toString() : `/${locale}/projects/${project.id}`} title={project.data.title} />

        <!-- Giscus comments -->
        <div class="giscus-container" style="margin-top: 3rem;">
          <script src="https://giscus.app/client.js"
            data-repo="felipetp-ctrl/felipetp-ctrl.github.io"
            data-repo-id="R_kgDORx26Tw"
            data-category="Announcements"
            data-category-id="DIC_kwDORx26T84C5kyz"
            data-mapping="pathname"
            data-strict="0"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="bottom"
            data-theme="preferred_color_scheme"
            data-lang={locale === 'en' ? 'en' : 'pt'}
            data-loading="lazy"
            crossorigin="anonymous"
            async
          ></script>
        </div>

        <!-- PDF Viewer for paper links -->
        {isPdfPaper && (
          <div class="pdf-viewer">
            <p class="pdf-viewer__label">
              <span data-i18n-pt="Visualizar artigo" data-i18n-en="View paper">Visualizar artigo</span>
            </p>
            <iframe
              src={project.data.paper}
              class="pdf-viewer__frame"
              title="Paper PDF"
              loading="lazy"
            ></iframe>
            <a href={project.data.paper} target="_blank" rel="noopener" class="btn btn--ghost" style="margin-top:0.75rem; display:inline-flex;">
              <span data-i18n-pt="Abrir em nova aba" data-i18n-en="Open in new tab">Abrir em nova aba</span>
            </a>
          </div>
        )}
      </div>
    </div>

    <!-- Related Projects -->
    {related.length > 0 && (
      <div class="container" style="margin-top: 3rem; padding-bottom: 3rem;">
        <div class="related-projects">
          <h3 class="related-projects__title">
            <span data-i18n-pt="Projetos Relacionados" data-i18n-en="Related Projects">Projetos Relacionados</span>
          </h3>
          <div class="related-projects__grid">
            {related.map(p => (
              <a href={`/${locale}/projects/${p.id}`} class="related-card">
                <span class="related-card__title"
                  data-i18n-pt={p.data.title}
                  data-i18n-en={p.data.titleEn || p.data.title}
                >{p.data.title}</span>
                <span class="related-card__shared">
                  {p.sharedCount} <span data-i18n-pt="tec. em comum" data-i18n-en="shared tech">tec. em comum</span>
                </span>
                <div class="tags" style="margin-top:0.5rem">
                  {p.data.technologies.slice(0,4).map((t: string) => (
                    <span class={`tag ${project.data.technologies.includes(t) ? 'tag--highlight' : ''}`}>{t}</span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    )}
  </div>
</BaseLayout>
