---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InteractiveTerminal from '../../components/InteractiveTerminal.astro';

export async function getStaticPaths() {
  return [{ params: { locale: 'pt' } }, { params: { locale: 'en' } }];
}

const { locale } = Astro.params as { locale: 'pt' | 'en' };

const skillGroups = [
  {
    labelPt: 'Linguagens & Dados',
    labelEn: 'Languages & Data',
    techs: ['Python', 'SQL', 'DAX', 'Pandas'],
  },
  {
    labelPt: 'Machine Learning',
    labelEn: 'Machine Learning',
    techs: ['scikit-learn', 'PyTorch', 'PyTorch Geometric', 'Feature Engineering', 'Detecção de Anomalias'],
  },
  {
    labelPt: 'Deep Learning',
    labelEn: 'Deep Learning',
    techs: ['Graph Neural Networks', 'EdgeConv', 'Autoencoders', 'SimCLR', 'NT-Xent'],
  },
  {
    labelPt: 'Analytics & Engenharia',
    labelEn: 'Analytics & Engineering',
    techs: ['ETL', 'Power BI', 'Streamlit', 'Matplotlib', 'KPIs'],
  },
  {
    labelPt: 'LLMs & RAG',
    labelEn: 'LLMs & RAG',
    techs: ['LlamaIndex', 'Google Gemini API', 'RAG', 'ReAct'],
  },
  {
    labelPt: 'Cloud & Ferramentas',
    labelEn: 'Cloud & Tools',
    techs: ['Microsoft Azure', 'Oracle Cloud', 'Docker', 'Git/GitHub'],
  },
];
---

<BaseLayout
  title="Sobre — Felipe Tomé Pereira"
  description="Analista de Dados com mais de 2 anos de experiência em analytics, ML pipelines, ETL e SQL. Projetos em Graph Neural Networks, aprendizado contrastivo e LLMs."
  ogImage={`/og/${locale}/about.png`}
  locale={locale}
>
  <div class="about-page">
    <div class="container">

      <!-- ── Header ── -->
      <header class="about-header">
        <h1 class="about-header__name">Felipe Tomé Pereira</h1>
        <p class="about-header__role"
          data-i18n-pt="Analista de Dados · Votorantim CoE · Curitiba, PR"
          data-i18n-en="Data Analyst · Votorantim CoE · Curitiba, PR"
        >Analista de Dados · Votorantim CoE · Curitiba, PR</p>
      </header>

      <!-- ── Resumo ── -->
      <section class="about-section reveal">
        <h2 data-i18n="about.bio-title">Resumo</h2>
        <div data-body-lang="pt">
          <p>
            Analista de Dados com mais de 2 anos de experiência em analytics, pipelines de Machine
            Learning, ETL, SQL e construção de indicadores para suporte à decisão em ambiente
            corporativo. Atua com modelagem, validação e monitoramento de dados, com interesse em
            ML aplicado, análise de risco, detecção de padrões atípicos e problemas analíticos de
            alta escala.
          </p>
          <p>
            Desenvolve paralelamente projetos em aprendizado não supervisionado, Graph Neural
            Networks e aprendizado contrastivo, com foco em representação de dados complexos e
            identificação de comportamentos não triviais.
          </p>
        </div>
        <div data-body-lang="en" style="display:none">
          <p>
            Data Analyst with over 2 years of experience in analytics, Machine Learning pipelines,
            ETL, SQL and KPI development for decision support in corporate environments. Works with
            data modeling, validation and monitoring, with interest in applied ML, risk analysis,
            anomaly detection and high-scale analytical problems.
          </p>
          <p>
            Concurrently develops projects in unsupervised learning, Graph Neural Networks and
            contrastive learning, focusing on complex data representation and non-trivial pattern
            identification.
          </p>
        </div>
      </section>

      <!-- ── Habilidades ── -->
      <section class="about-section reveal">
        <h2 data-i18n="about.skills">Habilidades Técnicas</h2>

        <!-- Tech Radar SVG Chart -->
        <div class="tech-radar-wrap">
          <canvas id="tech-radar" width="460" height="460" aria-label="Tech radar chart"></canvas>
        </div>

        <div class="skills-grid">
          {skillGroups.map((group, i) => (
            <div class="skill-group" data-radar-index={i}>
              <p class="skill-group__label"
                data-i18n-pt={group.labelPt}
                data-i18n-en={group.labelEn}
              >{group.labelPt}</p>
              <div class="tags">
                {group.techs.map(tech => (
                  <span class="tag">{tech}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ── Experiência ── -->
      <section class="about-section reveal">
        <h2 data-i18n="about.experience">Experiência Profissional</h2>
        <div class="timeline">

          <!-- Votorantim — Pleno -->
          <div class="timeline-item">
            <div class="timeline-item__year">
              <span data-i18n-pt="Jul. 2025 —" data-i18n-en="Jul. 2025 —">Jul. 2025 —</span><br />
              <span data-i18n="about.present">Presente</span>
            </div>
            <div>
              <p class="timeline-item__institution">Votorantim Center of Excellence</p>
              <p class="timeline-item__course"
                data-i18n-pt="Analista de Dados Pleno — Eficiência Operacional"
                data-i18n-en="Mid-level Data Analyst — Operational Efficiency"
              >Analista de Dados Pleno — Eficiência Operacional</p>
              <div data-body-lang="pt">
                <p class="timeline-item__desc">
                  Desenvolvimento de pipeline de ML para previsão de tempo de testes no SAP (regressão linear com validação cruzada).
                  Estruturação de indicadores financeiros e operacionais para monitoramento executivo.
                  Implementação de rotinas ETL integrando Panaya e SAP para dashboards analíticos.
                </p>
              </div>
              <div data-body-lang="en" style="display:none">
                <p class="timeline-item__desc">
                  Built end-to-end ML pipeline for SAP test time forecasting using cross-validated linear regression.
                  Structured financial and operational KPIs for executive monitoring.
                  Implemented ETL routines integrating Panaya and SAP for analytical dashboards.
                </p>
              </div>
            </div>
          </div>

          <!-- Votorantim — Processos -->
          <div class="timeline-item">
            <div class="timeline-item__year">Mar. 2024 —<br />Jul. 2025</div>
            <div>
              <p class="timeline-item__institution">Votorantim Center of Excellence</p>
              <p class="timeline-item__course"
                data-i18n-pt="Analista de Processos e Melhoria"
                data-i18n-en="Process & Improvement Analyst"
              >Analista de Processos e Melhoria</p>
              <div data-body-lang="pt">
                <p class="timeline-item__desc">
                  Liderança de automação e analytics com Microsoft Power Platform.
                  Desenvolvimento de dashboards Power BI com backend SQL para acompanhamento de SLAs e performance operacional.
                </p>
              </div>
              <div data-body-lang="en" style="display:none">
                <p class="timeline-item__desc">
                  Led automation and analytics initiatives using Microsoft Power Platform.
                  Developed Power BI dashboards with SQL backend for SLA tracking and operational performance analysis.
                </p>
              </div>
            </div>
          </div>

          <!-- Votorantim — Estágio -->
          <div class="timeline-item">
            <div class="timeline-item__year">Jul. 2023 —<br />Mar. 2024</div>
            <div>
              <p class="timeline-item__institution">Votorantim Center of Excellence</p>
              <p class="timeline-item__course"
                data-i18n-pt="Estagiário de Dados e Materiais"
                data-i18n-en="Data & Materials Intern"
              >Estagiário de Dados e Materiais</p>
              <div data-body-lang="pt">
                <p class="timeline-item__desc">
                  Desenvolvimento de consultas SQL para extração, validação e padronização de dados no SAP,
                  contribuindo para qualidade de dados, governança e suporte a auditorias internas.
                </p>
              </div>
              <div data-body-lang="en" style="display:none">
                <p class="timeline-item__desc">
                  Developed SQL queries for data extraction, validation and standardization in SAP,
                  supporting data quality, governance and internal audits.
                </p>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ── Pesquisa ── -->
      <section class="about-section reveal">
        <h2 data-i18n="about.research">Pesquisa</h2>
        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-item__year">
              <span data-i18n-pt="Jan. 2026 —" data-i18n-en="Jan. 2026 —">Jan. 2026 —</span><br />
              <span data-i18n="about.present">Presente</span>
            </div>
            <div>
              <p class="timeline-item__institution">Programa UNIGOU Remote</p>
              <p class="timeline-item__course"
                data-i18n-pt="Pesquisador Colaborador — Colaboração Acadêmica Internacional"
                data-i18n-en="Collaborative Researcher — International Academic Collaboration"
              >Pesquisador Colaborador — Colaboração Acadêmica Internacional</p>
              <div data-body-lang="pt">
                <p class="timeline-item__desc">
                  Pesquisa qualitativa internacional sobre interação humano-IA no trabalho do conhecimento,
                  envolvendo entrevistas, análise temática e discussão sobre produtividade, cognição e uso
                  responsável de sistemas inteligentes.
                </p>
              </div>
              <div data-body-lang="en" style="display:none">
                <p class="timeline-item__desc">
                  International qualitative research on human-AI interaction in knowledge work,
                  involving interviews, thematic analysis and discussion on productivity, cognition
                  and responsible use of intelligent systems.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Formação ── -->
      <section class="about-section reveal">
        <h2 data-i18n="about.education">Formação Acadêmica</h2>
        <div class="timeline">

          <div class="timeline-item">
            <div class="timeline-item__year"
              data-i18n-pt="Previsão: 2028"
              data-i18n-en="Expected: 2028"
            >Previsão: 2028</div>
            <div>
              <p class="timeline-item__institution">Pontifícia Universidade Católica do Paraná (PUCPR)</p>
              <p class="timeline-item__course"
                data-i18n-pt="Bacharelado em Administração de Empresas"
                data-i18n-en="Bachelor's in Business Administration"
              >Bacharelado em Administração de Empresas</p>
              <p class="timeline-item__desc">Curitiba, Brasil</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-item__year">2025</div>
            <div>
              <p class="timeline-item__institution">365DataScience</p>
              <p class="timeline-item__course"
                data-i18n-pt="Bootcamp de Ciência de Dados"
                data-i18n-en="Data Science Bootcamp"
              >Bootcamp de Ciência de Dados</p>
              <p class="timeline-item__desc">Online</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-item__year">2025</div>
            <div>
              <p class="timeline-item__institution">freeCodeCamp</p>
              <p class="timeline-item__course"
                data-i18n-pt="Análise de Dados com Python"
                data-i18n-en="Data Analysis with Python"
              >Análise de Dados com Python</p>
              <p class="timeline-item__desc">Online</p>
            </div>
          </div>

        </div>
      </section>

      <!-- ── Certificados ── -->
      <section class="about-section reveal">
        <h2 data-i18n-pt="Certificados" data-i18n-en="Certificates">Certificados</h2>
        <div class="certificates-grid">

          <div class="certificate-card">
            <p class="certificate-card__name"
              data-i18n-pt="Data Science Bootcamp"
              data-i18n-en="Data Science Bootcamp"
            >Data Science Bootcamp</p>
            <p class="certificate-card__issuer">365DataScience</p>
            <p class="certificate-card__date">2025</p>
          </div>

          <div class="certificate-card">
            <p class="certificate-card__name"
              data-i18n-pt="Data Analysis with Python"
              data-i18n-en="Data Analysis with Python"
            >Data Analysis with Python</p>
            <p class="certificate-card__issuer">freeCodeCamp</p>
            <p class="certificate-card__date">2025</p>
          </div>

        </div>
      </section>

      <!-- ── Terminal ── -->
      <section class="about-section reveal">
        <h2 data-i18n-pt="Terminal Interativo" data-i18n-en="Interactive Terminal">Terminal Interativo</h2>
        <InteractiveTerminal locale={locale} />
      </section>

      <!-- ── Contato ── -->
      <section class="about-section reveal">
        <h2 data-i18n="about.contact-title">Contato & Links</h2>
        <div class="about-links">
          <a href="/cv-felipe-tome-pereira.pdf" download class="btn btn--primary" data-i18n="about.download-cv">
            Baixar Currículo
          </a>
          <a href="https://github.com/felipetp-ctrl" target="_blank" rel="noopener" class="btn btn--outline">
            GitHub
          </a>
          <a href="https://linkedin.com/in/felipetpereira" target="_blank" rel="noopener" class="btn btn--outline">
            LinkedIn
          </a>
          <a href="mailto:felipetpereira1@gmail.com" class="btn btn--ghost">
            felipetpereira1@gmail.com
          </a>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-wrap">
          <h3 style="margin-top:2rem; margin-bottom:1rem; font-size:1rem;"
            data-i18n-pt="Enviar mensagem"
            data-i18n-en="Send a message"
          >Enviar mensagem</h3>
          <!-- Replace YOUR_FORM_ID with your Formspree form ID from https://formspree.io -->
          <form class="contact-form" action="https://formspree.io/f/mwvwldzy" method="POST" id="contact-form">
            <div class="contact-form__row">
              <label class="contact-form__label" for="contact-name">
                <span data-i18n-pt="Nome" data-i18n-en="Name">Nome</span>
              </label>
              <input class="contact-form__input" type="text" id="contact-name" name="name" required
                data-placeholder-pt="Seu nome"
                data-placeholder-en="Your name"
                placeholder="Seu nome" />
            </div>
            <div class="contact-form__row">
              <label class="contact-form__label" for="contact-email">Email</label>
              <input class="contact-form__input" type="email" id="contact-email" name="email" required
                data-placeholder-pt="seu@email.com"
                data-placeholder-en="your@email.com"
                placeholder="seu@email.com" />
            </div>
            <div class="contact-form__row">
              <label class="contact-form__label" for="contact-msg">
                <span data-i18n-pt="Mensagem" data-i18n-en="Message">Mensagem</span>
              </label>
              <textarea class="contact-form__input contact-form__textarea" id="contact-msg" name="message" rows="4" required
                data-placeholder-pt="Sua mensagem..."
                data-placeholder-en="Your message..."
                placeholder="Sua mensagem..."
              ></textarea>
            </div>
            <button type="submit" class="btn btn--primary" style="margin-top:0.5rem">
              <span data-i18n-pt="Enviar" data-i18n-en="Send">Enviar</span>
            </button>
            <p class="contact-form__success" id="contact-success" style="display:none; color:var(--green); font-size:0.85rem; margin-top:0.75rem;">
              <span data-i18n-pt="Mensagem enviada com sucesso!" data-i18n-en="Message sent successfully!">Mensagem enviada com sucesso!</span>
            </p>
          </form>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<script is:inline>
(function () {
  // ── Tech Radar ──
  function drawRadar() {
    var canvas = document.getElementById('tech-radar');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var W = canvas.width, H = canvas.height;
    var cx = W / 2, cy = H / 2;
    var r = Math.min(W, H) / 2 - 70;
    var labels = [];
    document.querySelectorAll('.skill-group').forEach(function (g) {
      var el = g.querySelector('.skill-group__label');
      if (el) labels.push(el.textContent.trim());
    });
    var n = labels.length;
    if (n < 3) return;
    var scores = [0.92, 0.85, 0.80, 0.75, 0.70, 0.65];

    var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    var textColor = isDark ? '#9c9890' : '#6b6760';
    var gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)';
    var fillColor = isDark ? 'rgba(122,173,223,0.18)' : 'rgba(27,58,107,0.12)';
    var strokeColor = isDark ? '#7aaddf' : '#1b3a6b';

    ctx.clearRect(0, 0, W, H);

    // Grid rings
    for (var ring = 1; ring <= 4; ring++) {
      ctx.beginPath();
      for (var i = 0; i < n; i++) {
        var angle = (Math.PI * 2 * i / n) - Math.PI / 2;
        var x = cx + (r * ring / 4) * Math.cos(angle);
        var y = cy + (r * ring / 4) * Math.sin(angle);
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      }
      ctx.closePath();
      ctx.strokeStyle = gridColor;
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Axes
    for (var i = 0; i < n; i++) {
      var angle = (Math.PI * 2 * i / n) - Math.PI / 2;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.lineTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle));
      ctx.strokeStyle = gridColor;
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Data polygon
    ctx.beginPath();
    for (var i = 0; i < n; i++) {
      var angle = (Math.PI * 2 * i / n) - Math.PI / 2;
      var score = scores[i] || 0.65;
      var x = cx + r * score * Math.cos(angle);
      var y = cy + r * score * Math.sin(angle);
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.fillStyle = fillColor;
    ctx.fill();
    ctx.strokeStyle = strokeColor;
    ctx.lineWidth = 2;
    ctx.stroke();

    // Points
    for (var i = 0; i < n; i++) {
      var angle = (Math.PI * 2 * i / n) - Math.PI / 2;
      var score = scores[i] || 0.65;
      var x = cx + r * score * Math.cos(angle);
      var y = cy + r * score * Math.sin(angle);
      ctx.beginPath();
      ctx.arc(x, y, 4, 0, Math.PI * 2);
      ctx.fillStyle = strokeColor;
      ctx.fill();
    }

    // Labels — wrap on '&' or '/' to stay within canvas bounds
    ctx.font = '11px IBM Plex Mono, monospace';
    ctx.fillStyle = textColor;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    var labelDist = r + 38;
    for (var i = 0; i < n; i++) {
      var angle = (Math.PI * 2 * i / n) - Math.PI / 2;
      var lx = cx + labelDist * Math.cos(angle);
      var ly = cy + labelDist * Math.sin(angle);
      var label = labels[i] || '';
      // Split on ' & ', ' / ', or at 14 chars if too long
      var parts;
      if (label.indexOf(' & ') !== -1) {
        parts = label.split(' & ');
      } else if (label.indexOf(' / ') !== -1) {
        parts = label.split(' / ');
      } else if (label.length > 14) {
        var mid = label.lastIndexOf(' ', 14);
        parts = mid > 0 ? [label.slice(0, mid), label.slice(mid + 1)] : [label.slice(0, 14), label.slice(14)];
      } else {
        parts = [label];
      }
      var lineH = 14;
      var startY = ly - ((parts.length - 1) * lineH) / 2;
      for (var j = 0; j < parts.length; j++) {
        ctx.fillText(parts[j], lx, startY + j * lineH);
      }
    }
  }

  document.addEventListener('astro:page-load', drawRadar);
  drawRadar();

  // Re-draw on theme change
  var obs = new MutationObserver(drawRadar);
  obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  // Update placeholders on lang change
  function applyPlaceholders() {
    var lang = window.__i18n ? window.__i18n.getLang() : 'pt';
    document.querySelectorAll('[data-placeholder-pt]').forEach(function (el) {
      el.placeholder = lang === 'en' ? (el.dataset.placeholderEn || '') : el.dataset.placeholderPt;
    });
  }
  document.addEventListener('astro:page-load', applyPlaceholders);
  document.addEventListener('langchange', applyPlaceholders);
  applyPlaceholders();

  // Contact form AJAX submission
  document.addEventListener('submit', function (e) {
    var form = e.target.closest('#contact-form');
    if (!form) return;
    e.preventDefault();
    var data = new FormData(form);
    fetch(form.action, { method: 'POST', body: data, headers: { 'Accept': 'application/json' } })
      .then(function (res) {
        var success = document.getElementById('contact-success');
        if (res.ok) {
          form.reset();
          if (success) success.style.display = '';
        } else {
          alert('Erro ao enviar. Tente novamente.');
        }
      })
      .catch(function () { alert('Erro ao enviar. Verifique sua conexão.'); });
  });
})();
</script>
