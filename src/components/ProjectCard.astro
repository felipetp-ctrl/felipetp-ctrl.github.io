---
interface Props {
  title: string;
  titleEn?: string;
  description: string;
  descriptionEn?: string;
  technologies: string[];
  mainResult: string;
  mainResultEn?: string;
  date: string;
  slug: string;
  github?: string;
  paper?: string;
  demo?: string;
  status: string;
  study: boolean;
  index: number;
  locale?: 'pt' | 'en';
}

const { title, titleEn, description, descriptionEn, technologies, mainResult, mainResultEn, date, slug, github, paper, demo, status, study, index, locale } = Astro.props;
const localePrefix = locale ? `/${locale}` : '';

const statusLabels: Record<string, string> = {
  completed: 'Concluído',
  published: 'Publicado',
  'in-progress': 'Em andamento',
};

const statusLabelsEn: Record<string, string> = {
  completed: 'Completed',
  published: 'Published',
  'in-progress': 'In Progress',
};

const num = String(index + 1).padStart(2, '0');
---

<article class={`project-card${study ? ' project-card--study' : ''}`} data-filter-tags={technologies.join(',')}>
  <div class="project-card__number">[{num}]</div>

  <div class="project-card__header">
    <a href={`${localePrefix}/projects/${slug}`} class="project-card__title"
      transition:name={`project-title-${slug}`}
      data-i18n-pt={title}
      data-i18n-en={titleEn || title}
    >{title}</a>
    <div style="display:flex; gap:0.4rem; align-items:center; flex-shrink:0;">
      {study && <span class="tag tag--study" data-i18n="tag.study">estudo</span>}
      <span
        class={`status status--${status}`}
        data-i18n-pt={statusLabels[status] ?? status}
        data-i18n-en={statusLabelsEn[status] ?? status}
      >{statusLabels[status] ?? status}</span>
    </div>
  </div>

  <p class="project-card__desc"
    data-i18n-pt={description}
    data-i18n-en={descriptionEn || description}
  >{description}</p>

  <div class="project-card__result"
    data-i18n-pt={mainResult}
    data-i18n-en={mainResultEn || mainResult}
  >{mainResult}</div>

  <div class="tags">
    {technologies.slice(0, 5).map((tech) => (
      <span class="tag">{tech}</span>
    ))}
    {technologies.length > 5 && (
      <span class="tag">+{technologies.length - 5}</span>
    )}
  </div>

  <div class="project-card__footer">
    <div class="project-card__links">
      <a href={`${localePrefix}/projects/${slug}`} class="btn btn--primary" data-i18n="card.view-details">Ver detalhes</a>
      {github && (
        <a href={github} target="_blank" rel="noopener" class="btn btn--ghost">
          GitHub
        </a>
      )}
      {demo && (
        <a href={demo} target="_blank" rel="noopener" class="btn btn--outline">
          Demo
        </a>
      )}
    </div>
    <span class="project-card__date">{date}</span>
  </div>
</article>

<style>
  .tag--study {
    background: #f0ece2;
    border-color: #c8be9e;
    color: #7a6c42;
  }
  .project-card--study {
    border-style: dashed;
  }
</style>
