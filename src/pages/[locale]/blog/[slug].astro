---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import RelatedPosts from '../../../components/RelatedPosts.astro';
import RssCta from '../../../components/RssCta.astro';
import { getCollection, render } from 'astro:content';
import { readingTime } from '../../../lib/readingTime';

export async function getStaticPaths() {
  const locales = ['pt', 'en'] as const;
  const allPosts = await getCollection('blog', p => !p.data.draft);
  return allPosts.flatMap((post) =>
    locales.map((locale) => ({
      params: { locale, slug: post.id },
      props: { post, locale, allPosts },
    })),
  );
}

const { post, locale, allPosts } = Astro.props as { post: any; locale: 'pt' | 'en'; allPosts: any[] };
const { Content, headings } = await render(post);
const minRead = readingTime(post.body ?? '');

// Series: find sibling posts in the same series
const seriesPosts = post.data.series
  ? allPosts
      .filter((p: any) => p.data.series === post.data.series)
      .sort((a: any, b: any) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
  : [];
const seriesIndex = seriesPosts.findIndex((p: any) => p.id === post.id);
const prevPost = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
const nextPost = seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;
---

<BaseLayout
  title={`${post.data.title} — Felipe Tomé Pereira | ML Research`}
  description={post.data.description}
  ogImage={`/og/${locale}/blog/${post.id}.png`}
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.date,
    "author": { "@type": "Person", "name": "Felipe Tomé Pereira" },
    "keywords": post.data.tags.join(', '),
    "url": Astro.site ? new URL(`/${locale}/blog/${post.id}`, Astro.site).toString() : undefined,
    "image": Astro.site ? new URL(`/og/${locale}/blog/${post.id}.png`, Astro.site).toString() : undefined
  })} slot="head" />
  <div class="blog-page">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Home', labelEn: 'Home', href: `/${locale}/` },
        { label: 'Blog', labelEn: 'Blog', href: `/${locale}/blog` },
        { label: post.data.title, labelEn: post.data.titleEn || post.data.title },
      ]} />
      <a href={`/${locale}/blog`} class="blog-page__back" data-i18n="blog.back">← Voltar ao blog</a>

      <!-- Focus mode button -->
      <button id="focus-mode-btn" class="focus-mode-btn" aria-label="Toggle focus mode">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/></svg>
        <span data-i18n-pt="Modo foco" data-i18n-en="Focus mode">Modo foco</span>
      </button>

      <!-- Meta -->
      <div class="blog-page__meta">
        <span class="blog-page__date">{post.data.date}</span>
        <span class="blog-page__reading-time reading-time-icon">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span data-i18n-pt={`${minRead} min de leitura`} data-i18n-en={`${minRead} min read`}>{minRead} min de leitura</span>
        </span>
        <div class="tags">
          {post.data.tags.map(t => (
            <a href={`/${locale}/blog/tags/${encodeURIComponent(t)}`} class="tag tag--link">{t}</a>
          ))}
        </div>
      </div>

      <!-- Title -->
      <h1 style="margin-bottom: 1rem; font-size: 1.6rem; line-height: 1.25;"
        transition:name={`blog-title-${post.id}`}
        data-i18n-pt={post.data.title}
        data-i18n-en={post.data.titleEn || post.data.title}
      >
        {post.data.title}
      </h1>

      <!-- Description -->
      <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.8; margin-bottom: 1.5rem;"
        data-i18n-pt={post.data.description}
        data-i18n-en={post.data.descriptionEn || post.data.description}
      >
        {post.data.description}
      </p>
    </div>

    <!-- Series indicator -->
    {seriesPosts.length > 1 && (
      <div class="container">
        <div class="series-box">
          <p class="series-box__label">
            <span data-i18n-pt={`Série: ${post.data.series}`} data-i18n-en={`Series: ${post.data.series}`}>
              Série: {post.data.series}
            </span>
            <span class="series-box__progress">{seriesIndex + 1}/{seriesPosts.length}</span>
          </p>
          <ol class="series-box__list">
            {seriesPosts.map((p: any, i: number) => (
              <li class={p.id === post.id ? 'series-box__item series-box__item--current' : 'series-box__item'}>
                {p.id === post.id
                  ? <span>{i + 1}. {p.data.title}</span>
                  : <a href={`/${locale}/blog/${p.id}`}>{i + 1}. {p.data.title}</a>
                }
              </li>
            ))}
          </ol>
        </div>
      </div>
    )}

    <!-- Body + TOC -->
    <div class="blog-body-wrap">
      <div class="blog-page__body">
        <Content />

        <!-- Share buttons -->
        <ShareButtons url={Astro.site ? new URL(`/${locale}/blog/${post.id}`, Astro.site).toString() : `/${locale}/blog/${post.id}`} title={post.data.title} />

        <!-- Related posts -->
        <RelatedPosts currentPost={post} allPosts={allPosts} locale={locale} />

        <!-- RSS CTA -->
        <div style="margin-top: 2rem;">
          <RssCta locale={locale} />
        </div>

        <!-- Giscus comments -->
        <div class="giscus-container" style="margin-top: 2rem;">
          <!-- To enable comments: 1. Enable GitHub Discussions on your repo 2. Install the Giscus GitHub App at https://giscus.app 3. Replace the data-* values below -->
          <script src="https://giscus.app/client.js"
            data-repo="felipetp-ctrl/felipetp-ctrl.github.io"
            data-repo-id="R_kgDORx26Tw"
            data-category="Announcements"
            data-category-id="DIC_kwDORx26T84C5kyz"
            data-mapping="pathname"
            data-strict="0"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="bottom"
            data-theme="preferred_color_scheme"
            data-lang={locale === 'en' ? 'en' : 'pt'}
            data-loading="lazy"
            crossorigin="anonymous"
            async
          ></script>
        </div>
      </div>
      <TableOfContents headings={headings} />
    </div>

    <!-- Series prev/next navigation -->
    {(prevPost || nextPost) && (
      <div class="container" style="margin-top:2rem; padding-bottom:2rem;">
        <div class="series-nav">
          {prevPost ? (
            <a href={`/${locale}/blog/${prevPost.id}`} class="series-nav__item series-nav__item--prev">
              <span class="series-nav__dir" data-i18n-pt="← Anterior" data-i18n-en="← Previous">← Anterior</span>
              <span class="series-nav__title"
                data-i18n-pt={prevPost.data.title}
                data-i18n-en={prevPost.data.titleEn || prevPost.data.title}
              >{prevPost.data.title}</span>
            </a>
          ) : <div />}
          {nextPost ? (
            <a href={`/${locale}/blog/${nextPost.id}`} class="series-nav__item series-nav__item--next">
              <span class="series-nav__dir" data-i18n-pt="Próximo →" data-i18n-en="Next →">Próximo →</span>
              <span class="series-nav__title"
                data-i18n-pt={nextPost.data.title}
                data-i18n-en={nextPost.data.titleEn || nextPost.data.title}
              >{nextPost.data.title}</span>
            </a>
          ) : <div />}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
