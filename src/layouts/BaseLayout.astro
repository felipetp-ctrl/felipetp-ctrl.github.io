---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  locale?: 'pt' | 'en';
}

const { title, description = 'ML Research Portfolio — Felipe Tome Pereira', ogImage, locale } = Astro.props;
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const pathLocale = pathParts[0] === 'pt' || pathParts[0] === 'en' ? (pathParts[0] as 'pt' | 'en') : undefined;
const currentLocale = locale ?? pathLocale ?? 'pt';
const localePrefix = currentLocale ? `/${currentLocale}` : '';

const localizedDefaultOgImage = currentLocale ? `/og/${currentLocale}/index.png` : '/og/index.png';
const effectiveOgImage = ogImage ?? localizedDefaultOgImage;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(effectiveOgImage, Astro.site);

const canonicalPath = Astro.url.pathname;
const pathWithoutLocale = pathLocale
  ? `/${pathParts.slice(1).join('/')}`
  : canonicalPath;
const normalizedPathWithoutLocale = pathWithoutLocale === '/' ? '/' : pathWithoutLocale.replace(/\/$/, '');
const ptHref = new URL(`/pt${normalizedPathWithoutLocale === '/' ? '/' : normalizedPathWithoutLocale}`, Astro.site);
const enHref = new URL(`/en${normalizedPathWithoutLocale === '/' ? '/' : normalizedPathWithoutLocale}`, Astro.site);

function withLocale(path: string): string {
  if (!path.startsWith('/')) return `${localePrefix}/${path}`;
  return `${localePrefix}${path}`;
}
---

<!doctype html>
<html lang={currentLocale === 'en' ? 'en' : 'pt-BR'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="pt-BR" href={ptHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={ptHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Felipe Tomé Pereira" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      // ── 1. Theme early detection (must run before paint to prevent flash) ──
      (function () {
        var saved = null;
        try { saved = localStorage.getItem('theme'); } catch (e) {}
        if (!saved) {
          var hour = new Date().getHours();
          var isNight = hour >= 18 || hour < 6;
          var prefDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          saved = (isNight || prefDark) ? 'dark' : 'light';
        }
        if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      })();

      // ── 2. i18n engine ──
      window.__i18n = (function () {
        var LANG_KEY = 'lang';
        var PATH_LANG = (function () {
          var m = window.location.pathname.match(/^\/(pt|en)(\/|$)/);
          return m ? m[1] : null;
        })();
        var UI = {
          pt: {
            'nav.projects': 'Projetos',
            'nav.activity': 'Atividade',
            'nav.about': 'Sobre',
            'filter.label': 'Filtrar por',
            'filter.all': 'Todos',
            'about.bio-title': 'Resumo',
            'about.skills': 'Habilidades Técnicas',
            'about.experience': 'Experiência Profissional',
            'about.research': 'Pesquisa',
            'about.education': 'Formação Acadêmica',
            'about.present': 'Presente',
            'about.download-cv': 'Baixar Currículo',
            'about.contact-title': 'Contato & Links',
            'hero.label': '// portfólio de pesquisa',
            'hero.bio': 'Estudante apaixonado por machine learning, estatística e bancos de dados. Busco aprender e aprofundar continuamente nesses temas, seja reimplementando papers, explorando datasets ou construindo pipelines do zero. Cada projeto é uma oportunidade de entender melhor como os dados se transformam em conhecimento.',
            'hero.contact': 'Contato',
            'projects.title': 'Projetos',
            'projects.works': 'trabalhos',
            'card.view-details': 'Ver detalhes',
            'tag.study': 'estudo',
            'heatmap.title': 'Atividade de commits',
            'heatmap.subtitle': 'últimos 12 meses · GitHub',
            'heatmap.less': 'Menos',
            'heatmap.more': 'Mais',
            'heatmap.stat.total': 'Commits totais',
            'heatmap.stat.streak': 'Maior sequência',
            'heatmap.stat.peak': 'Pico diário',
            'heatmap.stat.active': 'Dias ativos',
            'heatmap.months': ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'],
            'heatmap.days': ['Dom','','Ter','','Qui','','Sáb'],
            'heatmap.error': 'Não foi possível carregar os dados de contribuição do GitHub.',
            'heatmap.error.sub': 'Verifique se o perfil <strong>{u}</strong> é público.',
            'project.back': '← Voltar ao portfólio',
            'project.date-label': 'Data',
            'project.technologies-label': 'Tecnologias',
            'project.main-result': 'Resultado Principal',
            'project.view-github': 'Ver no GitHub',
            'project.paper': 'Paper / Artigo',
            'project.demo': 'Demo ao vivo',
            '404.title': 'Página não encontrada',
            '404.message': 'Essa página não existe ou foi movida.',
            '404.back': 'Voltar ao início',
            'toc.title': 'Índice',
            'nav.blog': 'Blog',
            'blog.back': '← Voltar ao blog',
            'blog.read-more': 'Ler mais',
            'blog.empty': 'Nenhum artigo publicado ainda.',
          },
          en: {
            'nav.projects': 'Projects',
            'nav.activity': 'Activity',
            'nav.about': 'About',
            'filter.label': 'Filter by',
            'filter.all': 'All',
            'about.bio-title': 'Summary',
            'about.skills': 'Technical Skills',
            'about.experience': 'Professional Experience',
            'about.research': 'Research',
            'about.education': 'Academic Background',
            'about.present': 'Present',
            'about.download-cv': 'Download CV',
            'about.contact-title': 'Contact & Links',
            'hero.label': '// research portfolio',
            'hero.bio': 'Student passionate about machine learning, statistics and databases. I continuously seek to learn and deepen my knowledge in these areas, whether by reimplementing papers, exploring datasets, or building pipelines from scratch. Each project is an opportunity to better understand how data transforms into knowledge.',
            'hero.contact': 'Contact',
            'projects.title': 'Projects',
            'projects.works': 'works',
            'card.view-details': 'View details',
            'tag.study': 'study',
            'heatmap.title': 'Commit activity',
            'heatmap.subtitle': 'last 12 months · GitHub',
            'heatmap.less': 'Less',
            'heatmap.more': 'More',
            'heatmap.stat.total': 'Total commits',
            'heatmap.stat.streak': 'Longest streak',
            'heatmap.stat.peak': 'Daily peak',
            'heatmap.stat.active': 'Active days',
            'heatmap.months': ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
            'heatmap.days': ['Sun','','Tue','','Thu','','Sat'],
            'heatmap.error': 'Could not load GitHub contribution data.',
            'heatmap.error.sub': 'Check if profile <strong>{u}</strong> is public.',
            'project.back': '← Back to portfolio',
            'project.date-label': 'Date',
            'project.technologies-label': 'Technologies',
            'project.main-result': 'Main Result',
            'project.view-github': 'View on GitHub',
            'project.paper': 'Paper / Article',
            'project.demo': 'Live Demo',
            '404.title': 'Page not found',
            '404.message': "This page doesn't exist or was moved.",
            '404.back': 'Back to home',
            'toc.title': 'Contents',
            'nav.blog': 'Blog',
            'blog.back': '← Back to blog',
            'blog.read-more': 'Read more',
            'blog.empty': 'No articles published yet.',
          },
        };
        function getLang() {
          if (PATH_LANG) return PATH_LANG;
          try { return localStorage.getItem(LANG_KEY) || 'pt'; } catch (e) { return 'pt'; }
        }
        function t(key) { return UI[getLang()][key]; }
        return { t: t, getLang: getLang, UI: UI };
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href={withLocale('/')} class="site-header__logo">
          <span>~/</span>felipetp
        </a>
        <nav>
          <ul class="site-nav">
            <li><a href={withLocale('/')}>Home</a></li>
            <li><a href={withLocale('/#projects')} data-i18n="nav.projects">Projetos</a></li>
            <li><a href={withLocale('/#activity')} data-i18n="nav.activity">Atividade</a></li>
            <li><a href={withLocale('/about')} data-i18n="nav.about">Sobre</a></li>
            <li><a href={withLocale('/blog')} data-i18n="nav.blog">Blog</a></li>
          </ul>
          <div class="header-controls">
            <div class="lang-switcher" role="group" aria-label="Language">
              <button class="lang-switcher__btn lang-switcher__btn--active" data-lang="pt">PT</button>
              <button class="lang-switcher__btn" data-lang="en">EN</button>
            </div>
            <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
              <svg class="theme-toggle__moon" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
              <svg class="theme-toggle__sun" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="12" cy="12" r="4"/>
                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
              </svg>
            </button>
            <!-- Hamburger: mobile only -->
            <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-label="Menu">
              <span class="nav-toggle__bar"></span>
              <span class="nav-toggle__bar"></span>
              <span class="nav-toggle__bar"></span>
            </button>
          </div>
        </nav>
      </div>
      <!-- Mobile dropdown menu -->
      <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
        <ul>
          <li><a href={withLocale('/')}>Home</a></li>
          <li><a href={withLocale('/#projects')} data-i18n="nav.projects">Projetos</a></li>
          <li><a href={withLocale('/#activity')} data-i18n="nav.activity">Atividade</a></li>
          <li><a href={withLocale('/about')} data-i18n="nav.about">Sobre</a></li>
          <li><a href={withLocale('/blog')} data-i18n="nav.blog">Blog</a></li>
        </ul>
      </div>
    </header>


    <main transition:animate="fade">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <span class="site-footer__copy">
          &copy; {new Date().getFullYear()} Felipe Tomé Pereira
        </span>
        <div class="site-footer__links">
          <a href="https://github.com/felipetp-ctrl" target="_blank" rel="noopener">GitHub</a>
          <a href="https://linkedin.com/in/felipetpereira" target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var LANG_KEY = 'lang';

        function getLang() {
          var m = window.location.pathname.match(/^\/(pt|en)(\/|$)/);
          if (m) return m[1];
          try { return localStorage.getItem(LANG_KEY) || 'pt'; } catch (e) { return 'pt'; }
        }

        function applyLang(lang) {
          var UI = window.__i18n.UI;
          document.documentElement.lang = lang === 'en' ? 'en' : 'pt-BR';
          document.querySelectorAll('[data-i18n]').forEach(function (el) {
            var val = UI[lang][el.dataset.i18n];
            if (val !== undefined && typeof val === 'string') el.textContent = val;
          });
          document.querySelectorAll('[data-i18n-en]').forEach(function (el) {
            el.textContent = lang === 'en' ? el.dataset.i18nEn : (el.dataset.i18nPt || el.textContent);
          });
          document.querySelectorAll('[data-body-lang]').forEach(function (el) {
            el.style.display = el.dataset.bodyLang === lang ? '' : 'none';
          });
          document.querySelectorAll('[data-label-pt]').forEach(function (el) {
            el.setAttribute('label', lang === 'en' ? (el.dataset.labelEn || '') : el.dataset.labelPt);
          });
          document.querySelectorAll('.lang-switcher__btn').forEach(function (btn) {
            btn.classList.toggle('lang-switcher__btn--active', btn.dataset.lang === lang);
          });
        }

        function localePath(pathname, nextLang) {
          if (pathname === '/') return '/' + nextLang + '/';
          if (/^\/(pt|en)(\/|$)/.test(pathname)) {
            return pathname.replace(/^\/(pt|en)(?=\/|$)/, '/' + nextLang);
          }
          return '/' + nextLang + (pathname.startsWith('/') ? pathname : '/' + pathname);
        }

        function getAutoTheme() {
          var hour = new Date().getHours();
          var prefDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          return (hour >= 18 || hour < 6 || prefDark) ? 'dark' : 'light';
        }

        function applyTheme(theme) {
          document.documentElement.classList.add('theme-transitioning');
          if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
          setTimeout(function () {
            document.documentElement.classList.remove('theme-transitioning');
          }, 300);
        }

        // Apply lang immediately to prevent flash on first load
        applyLang(getLang());

        // Redirect root to locale-specific entry.
        if (window.location.pathname === '/') {
          var browserLang = (navigator.language || '').toLowerCase();
          if (browserLang.indexOf('en') === 0) {
            window.location.replace('/en/');
          } else {
            window.location.replace('/pt/');
          }
          return;
        }

        // ── Event delegation — survives View Transitions DOM swaps ──
        document.addEventListener('click', function (e) {
          // Lang switcher
          var langBtn = e.target.closest('.lang-switcher__btn');
          if (langBtn) {
            var nextLang = langBtn.dataset.lang;
            try { localStorage.setItem(LANG_KEY, nextLang); } catch (ex) {}
            var currentLang = getLang();
            if (nextLang !== currentLang) {
              var nextPath = localePath(window.location.pathname, nextLang);
              window.location.assign(nextPath + window.location.search + window.location.hash);
              return;
            }
            applyLang(nextLang);
            document.dispatchEvent(new CustomEvent('langchange', { detail: { lang: nextLang } }));
            return;
          }
          // Theme toggle
          if (e.target.closest('#theme-toggle')) {
            var cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
            var nextTheme = cur === 'dark' ? 'light' : 'dark';
            try { localStorage.setItem('theme', nextTheme); } catch (ex) {}
            applyTheme(nextTheme);
            return;
          }
          // Hamburger open/close
          var toggle = e.target.closest('#nav-toggle');
          if (toggle) {
            var header = document.querySelector('.site-header');
            if (header) {
              var open = header.classList.toggle('nav-open');
              toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
              var mm = document.getElementById('mobile-menu');
              if (mm) mm.setAttribute('aria-hidden', open ? 'false' : 'true');
            }
            return;
          }
          // Mobile menu link — close menu
          if (e.target.closest('.mobile-menu a')) {
            var header2 = document.querySelector('.site-header');
            if (header2) {
              header2.classList.remove('nav-open');
              var nt2 = document.getElementById('nav-toggle');
              var mm2 = document.getElementById('mobile-menu');
              if (nt2) nt2.setAttribute('aria-expanded', 'false');
              if (mm2) mm2.setAttribute('aria-hidden', 'true');
            }
            return;
          }
          // Click outside header — close mobile menu
          var headerOut = document.querySelector('.site-header');
          if (headerOut && headerOut.classList.contains('nav-open') && !headerOut.contains(e.target)) {
            headerOut.classList.remove('nav-open');
            var ntOut = document.getElementById('nav-toggle');
            var mmOut = document.getElementById('mobile-menu');
            if (ntOut) ntOut.setAttribute('aria-expanded', 'false');
            if (mmOut) mmOut.setAttribute('aria-hidden', 'true');
          }
        });

        // Auto theme every minute when no saved preference
        setInterval(function () {
          try { if (!localStorage.getItem('theme')) applyTheme(getAutoTheme()); } catch (e) {}
        }, 60000);

        // ── View Transitions: copy data-theme to new document before swap ──
        document.addEventListener('astro:before-swap', function (e) {
          var theme = document.documentElement.getAttribute('data-theme');
          if (theme) {
            e.newDocument.documentElement.setAttribute('data-theme', theme);
          }
        });

        // ── View Transitions: re-apply lang after each navigation ──
        document.addEventListener('astro:page-load', function () {
          applyLang(getLang());
          // TOC scroll spy
          var tocLinks = document.querySelectorAll('.toc__link');
          if (tocLinks.length) {
            var headingEls = document.querySelectorAll('.project-page__body h2[id], .project-page__body h3[id], .blog-page__body h2[id], .blog-page__body h3[id]');
            if (headingEls.length) {
              var obs = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                  if (entry.isIntersecting) {
                    tocLinks.forEach(function (l) { l.classList.remove('toc__link--active'); });
                    var active = document.querySelector('.toc__link[href="#' + entry.target.id + '"]');
                    if (active) active.classList.add('toc__link--active');
                  }
                });
              }, { rootMargin: '-10% 0% -80% 0%', threshold: 0 });
              headingEls.forEach(function (el) { obs.observe(el); });
            }
          }
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
