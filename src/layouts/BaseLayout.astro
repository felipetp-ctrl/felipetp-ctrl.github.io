---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  locale?: 'pt' | 'en';
  accent?: string;
}

const { title, description = 'ML Research Portfolio — Felipe Tome Pereira', ogImage, locale, accent } = Astro.props;
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const pathLocale = pathParts[0] === 'pt' || pathParts[0] === 'en' ? (pathParts[0] as 'pt' | 'en') : undefined;
const currentLocale = locale ?? pathLocale ?? 'pt';
const localePrefix = currentLocale ? `/${currentLocale}` : '';

const localizedDefaultOgImage = currentLocale ? `/og/${currentLocale}/index.png` : '/og/index.png';
const effectiveOgImage = ogImage ?? localizedDefaultOgImage;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(effectiveOgImage, Astro.site);

const canonicalPath = Astro.url.pathname;
const pathWithoutLocale = pathLocale
  ? `/${pathParts.slice(1).join('/')}`
  : canonicalPath;
const normalizedPathWithoutLocale = pathWithoutLocale === '/' ? '/' : pathWithoutLocale.replace(/\/$/, '');
const ptHref = new URL(`/pt${normalizedPathWithoutLocale === '/' ? '/' : normalizedPathWithoutLocale}`, Astro.site);
const enHref = new URL(`/en${normalizedPathWithoutLocale === '/' ? '/' : normalizedPathWithoutLocale}`, Astro.site);

function withLocale(path: string): string {
  if (!path.startsWith('/')) return `${localePrefix}/${path}`;
  return `${localePrefix}${path}`;
}
---

<!doctype html>
<html lang={currentLocale === 'en' ? 'en' : 'pt-BR'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="pt-BR" href={ptHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={ptHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Felipe Tomé Pereira" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <slot name="head" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Felipe Tomé Pereira",
      "url": Astro.site?.toString(),
      "jobTitle": "Data Analyst",
      "sameAs": [
        "https://github.com/felipetp-ctrl",
        "https://linkedin.com/in/felipetpereira"
      ]
    })} />
    <ClientRouter />
    <script is:inline>
      // ── 1. Theme early detection (must run before paint to prevent flash) ──
      (function () {
        var saved = null;
        try { saved = localStorage.getItem('theme'); } catch (e) {}
        if (!saved) {
          var hour = new Date().getHours();
          var isNight = hour >= 18 || hour < 6;
          var prefDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          saved = (isNight || prefDark) ? 'dark' : 'light';
        }
        if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      })();

      // ── 2. i18n engine ──
      window.__i18n = (function () {
        var LANG_KEY = 'lang';
        var PATH_LANG = (function () {
          var m = window.location.pathname.match(/^\/(pt|en)(\/|$)/);
          return m ? m[1] : null;
        })();
        var UI = {
          pt: {
            'nav.projects': 'Projetos',
            'nav.activity': 'Atividade',
            'nav.about': 'Sobre',
            'filter.label': 'Filtrar por',
            'filter.all': 'Todos',
            'about.bio-title': 'Resumo',
            'about.skills': 'Habilidades Técnicas',
            'about.experience': 'Experiência Profissional',
            'about.research': 'Pesquisa',
            'about.education': 'Formação Acadêmica',
            'about.present': 'Presente',
            'about.download-cv': 'Baixar Currículo',
            'about.contact-title': 'Contato & Links',
            'hero.label': '// portfólio de pesquisa',
            'hero.bio': 'Estudante apaixonado por machine learning, estatística e bancos de dados. Busco aprender e aprofundar continuamente nesses temas, seja reimplementando papers, explorando datasets ou construindo pipelines do zero. Cada projeto é uma oportunidade de entender melhor como os dados se transformam em conhecimento.',
            'hero.contact': 'Contato',
            'projects.title': 'Projetos',
            'projects.works': 'trabalhos',
            'card.view-details': 'Ver detalhes',
            'tag.study': 'estudo',
            'heatmap.title': 'Atividade de commits',
            'heatmap.subtitle': 'últimos 12 meses · GitHub',
            'heatmap.less': 'Menos',
            'heatmap.more': 'Mais',
            'heatmap.stat.total': 'Commits totais',
            'heatmap.stat.streak': 'Maior sequência',
            'heatmap.stat.peak': 'Pico diário',
            'heatmap.stat.active': 'Dias ativos',
            'heatmap.months': ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'],
            'heatmap.days': ['Dom','','Ter','','Qui','','Sáb'],
            'heatmap.error': 'Não foi possível carregar os dados de contribuição do GitHub.',
            'heatmap.error.sub': 'Verifique se o perfil <strong>{u}</strong> é público.',
            'project.back': '← Voltar ao portfólio',
            'project.date-label': 'Data',
            'project.technologies-label': 'Tecnologias',
            'project.main-result': 'Resultado Principal',
            'project.view-github': 'Ver no GitHub',
            'project.paper': 'Paper / Artigo',
            'project.demo': 'Demo ao vivo',
            '404.title': 'Página não encontrada',
            '404.message': 'Essa página não existe ou foi movida.',
            '404.back': 'Voltar ao início',
            'toc.title': 'Índice',
            'nav.blog': 'Blog',
            'blog.back': '← Voltar ao blog',
            'blog.read-more': 'Ler mais',
            'blog.empty': 'Nenhum artigo publicado ainda.',
            'nav.search': 'Busca',
            'nav.publications': 'Publicações',
            'search.title': 'Busca',
            'search.placeholder': 'Pesquisar projetos e artigos...',
            'search.results': 'resultado(s)',
            'search.empty': 'Nenhum resultado encontrado.',
            'search.type.project': 'projeto',
            'search.type.blog': 'artigo',
          },
          en: {
            'nav.projects': 'Projects',
            'nav.activity': 'Activity',
            'nav.about': 'About',
            'filter.label': 'Filter by',
            'filter.all': 'All',
            'about.bio-title': 'Summary',
            'about.skills': 'Technical Skills',
            'about.experience': 'Professional Experience',
            'about.research': 'Research',
            'about.education': 'Academic Background',
            'about.present': 'Present',
            'about.download-cv': 'Download CV',
            'about.contact-title': 'Contact & Links',
            'hero.label': '// research portfolio',
            'hero.bio': 'Student passionate about machine learning, statistics and databases. I continuously seek to learn and deepen my knowledge in these areas, whether by reimplementing papers, exploring datasets, or building pipelines from scratch. Each project is an opportunity to better understand how data transforms into knowledge.',
            'hero.contact': 'Contact',
            'projects.title': 'Projects',
            'projects.works': 'works',
            'card.view-details': 'View details',
            'tag.study': 'study',
            'heatmap.title': 'Commit activity',
            'heatmap.subtitle': 'last 12 months · GitHub',
            'heatmap.less': 'Less',
            'heatmap.more': 'More',
            'heatmap.stat.total': 'Total commits',
            'heatmap.stat.streak': 'Longest streak',
            'heatmap.stat.peak': 'Daily peak',
            'heatmap.stat.active': 'Active days',
            'heatmap.months': ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
            'heatmap.days': ['Sun','','Tue','','Thu','','Sat'],
            'heatmap.error': 'Could not load GitHub contribution data.',
            'heatmap.error.sub': 'Check if profile <strong>{u}</strong> is public.',
            'project.back': '← Back to portfolio',
            'project.date-label': 'Date',
            'project.technologies-label': 'Technologies',
            'project.main-result': 'Main Result',
            'project.view-github': 'View on GitHub',
            'project.paper': 'Paper / Article',
            'project.demo': 'Live Demo',
            '404.title': 'Page not found',
            '404.message': "This page doesn't exist or was moved.",
            '404.back': 'Back to home',
            'toc.title': 'Contents',
            'nav.blog': 'Blog',
            'blog.back': '← Back to blog',
            'blog.read-more': 'Read more',
            'blog.empty': 'No articles published yet.',
            'nav.search': 'Search',
            'nav.publications': 'Publications',
            'search.title': 'Search',
            'search.placeholder': 'Search projects and articles...',
            'search.results': 'result(s)',
            'search.empty': 'No results found.',
            'search.type.project': 'project',
            'search.type.blog': 'article',
          },
        };
        function getLang() {
          if (PATH_LANG) return PATH_LANG;
          try { return localStorage.getItem(LANG_KEY) || 'pt'; } catch (e) { return 'pt'; }
        }
        function t(key) { return UI[getLang()][key]; }
        return { t: t, getLang: getLang, UI: UI };
      })();
    </script>
  </head>
  <body data-accent={accent || undefined}>
    <a class="skip-link" href="#main-content" data-i18n-pt="Pular para o conteúdo" data-i18n-en="Skip to content">Pular para o conteúdo</a>
    <div id="sr-announce" aria-live="polite" aria-atomic="true"></div>
    <header class="site-header">
      <div class="site-header__inner">
        <a href={withLocale('/')} class="site-header__logo">
          <span>~/</span>felipetp
        </a>
        <nav aria-label="Navegação principal">
          <ul class="site-nav">
            <li><a href={withLocale('/')}>Home</a></li>
            <li><a href={withLocale('/#projects')} data-i18n="nav.projects">Projetos</a></li>
            <li><a href={withLocale('/#activity')} data-i18n="nav.activity">Atividade</a></li>
            <li><a href={withLocale('/about')} data-i18n="nav.about">Sobre</a></li>
            <li><a href={withLocale('/publications')} data-i18n="nav.publications">Publicações</a></li>
            <li><a href={withLocale('/blog')} data-i18n="nav.blog">Blog</a></li>
            <li><a href={withLocale('/search')} data-i18n="nav.search">Busca</a></li>
          </ul>
          <div class="header-controls">
            <div class="lang-switcher" role="group" aria-label="Language">
              <button class="lang-switcher__btn lang-switcher__btn--active" data-lang="pt">PT</button>
              <button class="lang-switcher__btn" data-lang="en">EN</button>
            </div>
            <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
              <svg class="theme-toggle__moon" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
              <svg class="theme-toggle__sun" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="12" cy="12" r="4"/>
                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
              </svg>
            </button>
            <!-- Hamburger: mobile only -->
            <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-label="Menu">
              <span class="nav-toggle__bar"></span>
              <span class="nav-toggle__bar"></span>
              <span class="nav-toggle__bar"></span>
            </button>
          </div>
        </nav>
      </div>
      <!-- Mobile dropdown menu -->
      <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
        <ul>
          <li><a href={withLocale('/')}>Home</a></li>
          <li><a href={withLocale('/#projects')} data-i18n="nav.projects">Projetos</a></li>
          <li><a href={withLocale('/#activity')} data-i18n="nav.activity">Atividade</a></li>
          <li><a href={withLocale('/about')} data-i18n="nav.about">Sobre</a></li>
          <li><a href={withLocale('/publications')} data-i18n="nav.publications">Publicações</a></li>
          <li><a href={withLocale('/blog')} data-i18n="nav.blog">Blog</a></li>
          <li><a href={withLocale('/search')} data-i18n="nav.search">Busca</a></li>
        </ul>
      </div>
    </header>


    <!-- Reading progress bar -->
    <div id="reading-progress" aria-hidden="true"></div>

    <main id="main-content" transition:animate="fade">
      <slot />
    </main>

    <!-- Back to top button -->
    <button id="back-to-top" aria-label="Back to top" class="back-to-top">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 15l-6-6-6 6"/>
      </svg>
    </button>

    <!-- Ctrl+K Command Palette -->
    <div id="cmd-overlay" class="cmd-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Busca rápida">
      <div class="cmd-modal" role="document">
        <div class="cmd-modal__header">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="cmd-modal__icon" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input id="cmd-input" type="search" class="cmd-modal__input" autocomplete="off" spellcheck="false"
            aria-label="Pesquisar"
            data-placeholder-pt="Pesquisar projetos e artigos..."
            data-placeholder-en="Search projects and articles..."
            placeholder="Pesquisar projetos e artigos..." />
          <kbd class="cmd-modal__esc">ESC</kbd>
        </div>
        <div id="cmd-results" class="cmd-modal__results"></div>
      </div>
    </div>

    <!-- Keyboard Shortcuts Guide -->
    <div id="kbd-guide-overlay" class="kbd-guide-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Atalhos de teclado">
      <div class="kbd-guide">
        <p class="kbd-guide__title" data-i18n-pt="Atalhos de Teclado" data-i18n-en="Keyboard Shortcuts">Atalhos de Teclado</p>
        <div class="kbd-guide__row">
          <span class="kbd-guide__desc" data-i18n-pt="Busca rápida" data-i18n-en="Quick search">Busca rápida</span>
          <span class="kbd-guide__key">Ctrl + K</span>
        </div>
        <div class="kbd-guide__row">
          <span class="kbd-guide__desc" data-i18n-pt="Alternar tema" data-i18n-en="Toggle theme">Alternar tema</span>
          <span class="kbd-guide__key">T</span>
        </div>
        <div class="kbd-guide__row">
          <span class="kbd-guide__desc" data-i18n-pt="Modo leitura" data-i18n-en="Focus mode">Modo leitura</span>
          <span class="kbd-guide__key">F</span>
        </div>
        <div class="kbd-guide__row">
          <span class="kbd-guide__desc" data-i18n-pt="Este guia" data-i18n-en="This guide">Este guia</span>
          <span class="kbd-guide__key">?</span>
        </div>
        <div class="kbd-guide__row">
          <span class="kbd-guide__desc" data-i18n-pt="Fechar modal" data-i18n-en="Close modal">Fechar modal</span>
          <span class="kbd-guide__key">Esc</span>
        </div>
      </div>
    </div>

    <!-- Lightbox -->
    <div id="lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Visualizador de imagem">
      <button class="lightbox__close" id="lightbox-close" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
      <img id="lightbox-img" src="" alt="" class="lightbox__img" />
      <p id="lightbox-caption" class="lightbox__caption"></p>
    </div>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <span class="site-footer__copy">
          &copy; {new Date().getFullYear()} Felipe Tomé Pereira
        </span>
        <div class="site-footer__links">
          <a href="https://github.com/felipetp-ctrl" target="_blank" rel="noopener">GitHub</a>
          <a href="https://linkedin.com/in/felipetpereira" target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var LANG_KEY = 'lang';

        function getLang() {
          var m = window.location.pathname.match(/^\/(pt|en)(\/|$)/);
          if (m) return m[1];
          try { return localStorage.getItem(LANG_KEY) || 'pt'; } catch (e) { return 'pt'; }
        }

        function applyLang(lang) {
          var UI = window.__i18n.UI;
          document.documentElement.lang = lang === 'en' ? 'en' : 'pt-BR';
          document.querySelectorAll('[data-i18n]').forEach(function (el) {
            var val = UI[lang][el.dataset.i18n];
            if (val !== undefined && typeof val === 'string') el.textContent = val;
          });
          document.querySelectorAll('[data-i18n-en]').forEach(function (el) {
            el.textContent = lang === 'en' ? el.dataset.i18nEn : (el.dataset.i18nPt || el.textContent);
          });
          document.querySelectorAll('[data-body-lang]').forEach(function (el) {
            el.style.display = el.dataset.bodyLang === lang ? '' : 'none';
          });
          document.querySelectorAll('[data-label-pt]').forEach(function (el) {
            el.setAttribute('label', lang === 'en' ? (el.dataset.labelEn || '') : el.dataset.labelPt);
          });
          document.querySelectorAll('.lang-switcher__btn').forEach(function (btn) {
            btn.classList.toggle('lang-switcher__btn--active', btn.dataset.lang === lang);
          });
        }

        function localePath(pathname, nextLang) {
          if (pathname === '/') return '/' + nextLang + '/';
          if (/^\/(pt|en)(\/|$)/.test(pathname)) {
            return pathname.replace(/^\/(pt|en)(?=\/|$)/, '/' + nextLang);
          }
          return '/' + nextLang + (pathname.startsWith('/') ? pathname : '/' + pathname);
        }

        function getAutoTheme() {
          var hour = new Date().getHours();
          var prefDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          return (hour >= 18 || hour < 6 || prefDark) ? 'dark' : 'light';
        }

        function applyTheme(theme) {
          document.documentElement.classList.add('theme-transitioning');
          if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
          setTimeout(function () {
            document.documentElement.classList.remove('theme-transitioning');
          }, 300);
        }

        // Apply lang immediately to prevent flash on first load
        applyLang(getLang());
        // Init interactive features on first load
        document.addEventListener('DOMContentLoaded', function () {
          updateActiveNav();
          initReadingProgress();
          initBackToTop();
          initCopyCode();
          initLightbox();
        });

        // Redirect root to locale-specific entry.
        if (window.location.pathname === '/') {
          var browserLang = (navigator.language || '').toLowerCase();
          if (browserLang.indexOf('en') === 0) {
            window.location.replace('/en/');
          } else {
            window.location.replace('/pt/');
          }
          return;
        }

        // ── Event delegation — survives View Transitions DOM swaps ──
        document.addEventListener('click', function (e) {
          // Lang switcher
          var langBtn = e.target.closest('.lang-switcher__btn');
          if (langBtn) {
            var nextLang = langBtn.dataset.lang;
            try { localStorage.setItem(LANG_KEY, nextLang); } catch (ex) {}
            var currentLang = getLang();
            if (nextLang !== currentLang) {
              var nextPath = localePath(window.location.pathname, nextLang);
              window.location.assign(nextPath + window.location.search + window.location.hash);
              return;
            }
            applyLang(nextLang);
            document.dispatchEvent(new CustomEvent('langchange', { detail: { lang: nextLang } }));
            return;
          }
          // Theme toggle
          if (e.target.closest('#theme-toggle')) {
            var cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
            var nextTheme = cur === 'dark' ? 'light' : 'dark';
            try { localStorage.setItem('theme', nextTheme); } catch (ex) {}
            applyTheme(nextTheme);
            syncGiscusTheme(nextTheme);
            return;
          }
          // Hamburger open/close
          var toggle = e.target.closest('#nav-toggle');
          if (toggle) {
            var header = document.querySelector('.site-header');
            if (header) {
              var open = header.classList.toggle('nav-open');
              toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
              var mm = document.getElementById('mobile-menu');
              if (mm) mm.setAttribute('aria-hidden', open ? 'false' : 'true');
            }
            return;
          }
          // Mobile menu link — close menu
          if (e.target.closest('.mobile-menu a')) {
            var header2 = document.querySelector('.site-header');
            if (header2) {
              header2.classList.remove('nav-open');
              var nt2 = document.getElementById('nav-toggle');
              var mm2 = document.getElementById('mobile-menu');
              if (nt2) nt2.setAttribute('aria-expanded', 'false');
              if (mm2) mm2.setAttribute('aria-hidden', 'true');
            }
            return;
          }
          // Click outside header — close mobile menu
          var headerOut = document.querySelector('.site-header');
          if (headerOut && headerOut.classList.contains('nav-open') && !headerOut.contains(e.target)) {
            headerOut.classList.remove('nav-open');
            var ntOut = document.getElementById('nav-toggle');
            var mmOut = document.getElementById('mobile-menu');
            if (ntOut) ntOut.setAttribute('aria-expanded', 'false');
            if (mmOut) mmOut.setAttribute('aria-hidden', 'true');
          }
        });

        // ── Giscus theme sync ──
        function syncGiscusTheme(theme) {
          var iframe = document.querySelector('iframe.giscus-frame');
          if (!iframe) return;
          iframe.contentWindow.postMessage(
            { giscus: { setConfig: { theme: theme === 'dark' ? 'dark' : 'light' } } },
            'https://giscus.app'
          );
        }

        // Auto theme every minute when no saved preference
        setInterval(function () {
          try { if (!localStorage.getItem('theme')) applyTheme(getAutoTheme()); } catch (e) {}
        }, 60000);

        // ── View Transitions: copy data-theme to new document before swap ──
        document.addEventListener('astro:before-swap', function (e) {
          var theme = document.documentElement.getAttribute('data-theme');
          if (theme) {
            e.newDocument.documentElement.setAttribute('data-theme', theme);
          }
        });

        // ── Reading progress bar ──
        function initReadingProgress() {
          var bar = document.getElementById('reading-progress');
          if (!bar) return;
          var body = document.querySelector('.project-page__body, .blog-page__body');
          if (!body) { bar.style.display = 'none'; return; }
          bar.style.display = 'block';
          function updateProgress() {
            var scrollTop = window.scrollY;
            var docH = document.documentElement.scrollHeight - window.innerHeight;
            bar.style.width = docH > 0 ? Math.min(100, (scrollTop / docH) * 100) + '%' : '0%';
          }
          window.addEventListener('scroll', updateProgress, { passive: true });
          updateProgress();
        }

        // ── Back to top ──
        function initBackToTop() {
          var btn = document.getElementById('back-to-top');
          if (!btn) return;
          function onScroll() { btn.classList.toggle('back-to-top--visible', window.scrollY > 300); }
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }
        document.addEventListener('click', function (e) {
          if (e.target.closest('#back-to-top')) window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        // ── Copy code buttons ──
        function initCopyCode() {
          document.querySelectorAll('.project-page__body pre, .blog-page__body pre').forEach(function (pre) {
            if (pre.querySelector('.copy-btn')) return;
            var btn = document.createElement('button');
            btn.className = 'copy-btn';
            btn.setAttribute('aria-label', 'Copy code');
            btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
            pre.style.position = 'relative';
            pre.appendChild(btn);
          });
        }
        document.addEventListener('click', function (e) {
          var btn = e.target.closest('.copy-btn');
          if (!btn) return;
          var pre = btn.closest('pre');
          var code = pre ? (pre.querySelector('code') || pre) : null;
          if (!code) return;
          navigator.clipboard.writeText(code.textContent || '').then(function () {
            btn.classList.add('copy-btn--copied');
            setTimeout(function () { btn.classList.remove('copy-btn--copied'); }, 1800);
          });
        });

        // ── Image lightbox ──
        function initLightbox() {
          document.querySelectorAll('.project-page__body img, .blog-page__body img').forEach(function (img) {
            if (img.dataset.lightboxReady) return;
            img.dataset.lightboxReady = '1';
            img.style.cursor = 'zoom-in';
          });
        }
        document.addEventListener('click', function (e) {
          var img = e.target.closest('.project-page__body img, .blog-page__body img');
          if (img) {
            var lb = document.getElementById('lightbox');
            var lbImg = document.getElementById('lightbox-img');
            var lbCap = document.getElementById('lightbox-caption');
            if (lb && lbImg) {
              lbImg.src = img.src;
              lbImg.alt = img.alt || '';
              if (lbCap) lbCap.textContent = img.alt || '';
              lb.setAttribute('aria-hidden', 'false');
              lb.classList.add('lightbox--open');
              document.body.style.overflow = 'hidden';
            }
            return;
          }
          if (e.target.closest('#lightbox-close') || e.target.id === 'lightbox') {
            var lb2 = document.getElementById('lightbox');
            if (lb2) {
              lb2.classList.remove('lightbox--open');
              lb2.setAttribute('aria-hidden', 'true');
              document.body.style.overflow = '';
            }
          }
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            var lb = document.getElementById('lightbox');
            if (lb && lb.classList.contains('lightbox--open')) {
              lb.classList.remove('lightbox--open');
              lb.setAttribute('aria-hidden', 'true');
              document.body.style.overflow = '';
            }
          }
        });

        // ── Ctrl+K Command Palette ──
        var _cmdData = null;
        function openCmd() {
          var overlay = document.getElementById('cmd-overlay');
          var input = document.getElementById('cmd-input');
          if (!overlay || !input) return;
          overlay.setAttribute('aria-hidden', 'false');
          overlay.classList.add('cmd-overlay--open');
          document.body.style.overflow = 'hidden';
          input.value = '';
          document.getElementById('cmd-results').innerHTML = '';
          // Update placeholder for current lang
          var lang = getLang();
          input.placeholder = lang === 'en' ? 'Search projects and articles...' : 'Pesquisar projetos e artigos...';
          input.focus();
          trapFocus(overlay);
          if (!_cmdData) {
            var locale = (window.location.pathname.match(/^\/(pt|en)/) || [])[1] || 'pt';
            fetch('/' + locale + '/search-data.json')
              .then(function (r) { return r.json(); })
              .then(function (d) { _cmdData = d; });
          }
        }
        function closeCmd() {
          var overlay = document.getElementById('cmd-overlay');
          if (!overlay) return;
          overlay.classList.remove('cmd-overlay--open');
          overlay.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }
        // ── Kbd guide ──
        function openKbdGuide() {
          var el = document.getElementById('kbd-guide-overlay');
          if (el) { el.classList.add('kbd-guide-overlay--open'); el.setAttribute('aria-hidden', 'false'); }
        }
        function closeKbdGuide() {
          var el = document.getElementById('kbd-guide-overlay');
          if (el) { el.classList.remove('kbd-guide-overlay--open'); el.setAttribute('aria-hidden', 'true'); }
        }
        document.addEventListener('click', function (e) {
          var ov = document.getElementById('kbd-guide-overlay');
          if (ov && ov.classList.contains('kbd-guide-overlay--open') && e.target === ov) closeKbdGuide();
        });

        document.addEventListener('keydown', function (e) {
          if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            var overlay = document.getElementById('cmd-overlay');
            if (overlay && overlay.classList.contains('cmd-overlay--open')) closeCmd();
            else openCmd();
            return;
          }
          // Only fire single-key shortcuts when not in an input
          var tag = document.activeElement && document.activeElement.tagName;
          var inInput = tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
          if (!inInput && !e.ctrlKey && !e.metaKey && !e.altKey) {
            if (e.key === '?') { e.preventDefault(); openKbdGuide(); return; }
            if (e.key === 't' || e.key === 'T') {
              var cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
              var nt = cur === 'dark' ? 'light' : 'dark';
              try { localStorage.setItem('theme', nt); } catch(ex) {}
              applyTheme(nt); syncGiscusTheme(nt); return;
            }
            if (e.key === 'f' || e.key === 'F') {
              document.body.classList.toggle('focus-mode'); return;
            }
          }
          if (e.key === 'Escape') {
            closeKbdGuide();
            closeCmd();
          }
          // Arrow navigation in command palette
          var overlay2 = document.getElementById('cmd-overlay');
          if (!overlay2 || !overlay2.classList.contains('cmd-overlay--open')) return;
          if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp' && e.key !== 'Enter') return;
          var results2 = document.querySelectorAll('#cmd-results .cmd-result');
          if (!results2.length) return;
          e.preventDefault();
          var active = document.querySelector('#cmd-results .cmd-result--focused');
          var idx = -1;
          results2.forEach(function (el, i) { if (el === active) idx = i; });
          if (e.key === 'ArrowDown') idx = (idx + 1) % results2.length;
          else if (e.key === 'ArrowUp') idx = (idx - 1 + results2.length) % results2.length;
          else if (e.key === 'Enter' && active) { active.click(); return; }
          results2.forEach(function (el) { el.classList.remove('cmd-result--focused'); });
          results2[idx].classList.add('cmd-result--focused');
          results2[idx].scrollIntoView({ block: 'nearest' });
        });
        document.addEventListener('click', function (e) {
          var overlay = document.getElementById('cmd-overlay');
          if (overlay && overlay.classList.contains('cmd-overlay--open')) {
            if (e.target === overlay) closeCmd();
          }
        });
        document.addEventListener('input', function (e) {
          if (e.target.id !== 'cmd-input') return;
          var q = e.target.value.trim().toLowerCase();
          var results = document.getElementById('cmd-results');
          if (!results) return;
          if (!q || !_cmdData) { results.innerHTML = ''; return; }
          var lang = getLang();
          var filtered = _cmdData.filter(function (item) {
            var title = lang === 'en' ? item.titleEn : item.title;
            var desc = lang === 'en' ? item.descriptionEn : item.description;
            return title.toLowerCase().includes(q) || desc.toLowerCase().includes(q) ||
              item.tags.some(function (t) { return t.toLowerCase().includes(q); });
          }).slice(0, 8);
          if (!filtered.length) {
            results.innerHTML = '<p class="cmd-modal__empty">' + (lang === 'en' ? 'No results found.' : 'Nenhum resultado encontrado.') + '</p>';
            return;
          }
          results.innerHTML = filtered.map(function (item) {
            var title = lang === 'en' ? item.titleEn : item.title;
            var badge = item.type === 'project' ? (lang === 'en' ? 'project' : 'projeto') : 'blog';
            return '<a href="' + item.url + '" class="cmd-result"><span class="cmd-result__badge cmd-result__badge--' + item.type + '">' + badge + '</span><span class="cmd-result__title">' + title + '</span></a>';
          }).join('');
        });
        document.addEventListener('click', function (e) {
          if (e.target.closest('.cmd-result')) closeCmd();
        });

        // ── Focus mode button ──
        document.addEventListener('click', function (e) {
          if (e.target.closest('#focus-mode-btn')) {
            document.body.classList.toggle('focus-mode');
          }
        });

        // ── Copy URL buttons (share & RSS) ──
        document.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-copy-url]');
          if (!btn) return;
          var url = btn.dataset.copyUrl;
          if (!url) return;
          var isInstagram = btn.dataset.instagram === 'true';
          // Open Instagram synchronously (before async clipboard) to avoid popup blocker
          if (isInstagram) {
            window.open('https://www.instagram.com/', '_blank', 'noopener');
          }
          navigator.clipboard.writeText(url).then(function () {
            btn.classList.add('share-btn--copied');
            setTimeout(function () { btn.classList.remove('share-btn--copied'); }, 1800);
          });
        });

        // ── Scroll reveal animations ──
        function initReveal() {
          var els = document.querySelectorAll('.reveal:not(.reveal--visible)');
          if (!els.length) return;
          var revealObs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('reveal--visible');
                revealObs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.08 });
          els.forEach(function (el) { revealObs.observe(el); });
        }

        // ── Active nav indicator ──
        function updateActiveNav() {
          var path = window.location.pathname;
          document.querySelectorAll('.site-nav a, .mobile-menu a').forEach(function (a) {
            var href = a.getAttribute('href') || '';
            // Strip hash for comparison
            var hrefPath = href.split('#')[0];
            var isActive = false;
            if (hrefPath && hrefPath !== '/' && hrefPath !== '/pt/' && hrefPath !== '/en/') {
              isActive = path.startsWith(hrefPath);
            }
            a.classList.toggle('active', isActive);
          });
        }

        // ── Focus trap for modals ──
        function trapFocus(modalEl) {
          var focusable = modalEl.querySelectorAll('a[href], button:not([disabled]), input, textarea, [tabindex]:not([tabindex="-1"])');
          if (!focusable.length) return;
          var first = focusable[0], last = focusable[focusable.length - 1];
          modalEl.addEventListener('keydown', function handler(e) {
            if (e.key !== 'Tab') return;
            if (!modalEl.classList.contains('cmd-overlay--open') && !modalEl.classList.contains('lightbox--open')) {
              modalEl.removeEventListener('keydown', handler);
              return;
            }
            if (e.shiftKey && document.activeElement === first) {
              e.preventDefault(); last.focus();
            } else if (!e.shiftKey && document.activeElement === last) {
              e.preventDefault(); first.focus();
            }
          });
        }

        // ── View Transitions: re-apply lang after each navigation ──
        document.addEventListener('astro:page-load', function () {
          applyLang(getLang());
          updateActiveNav();
          initReadingProgress();
          initBackToTop();
          initCopyCode();
          initLightbox();
          initReveal();
          // Reset cmd data on locale change
          _cmdData = null;
          // TOC scroll spy
          var tocLinks = document.querySelectorAll('.toc__link');
          if (tocLinks.length) {
            var headingEls = document.querySelectorAll('.project-page__body h2[id], .project-page__body h3[id], .blog-page__body h2[id], .blog-page__body h3[id]');
            if (headingEls.length) {
              var obs = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                  if (entry.isIntersecting) {
                    tocLinks.forEach(function (l) { l.classList.remove('toc__link--active'); });
                    var active = document.querySelector('.toc__link[href="#' + entry.target.id + '"]');
                    if (active) active.classList.add('toc__link--active');
                  }
                });
              }, { rootMargin: '-10% 0% -80% 0%', threshold: 0 });
              headingEls.forEach(function (el) { obs.observe(el); });
            }
          }
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
