---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import CommitHeatmap from '../components/CommitHeatmap.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Felipe Tome Pereira — ML Research">
  <!-- ── Hero ── -->
  <section class="hero">
    <div class="container--wide">
      <p class="hero__label">// portfólio de pesquisa</p>
      <h1 class="hero__name">Felipe Tome Pereira</h1>
      <p class="hero__role">Machine Learning Engineer &amp; Researcher</p>
      <p class="hero__bio">
        Trabalho na interseção entre pesquisa e engenharia de ML, com foco em
        processamento de linguagem natural, séries temporais e sistemas de IA
        aplicados ao contexto brasileiro. Interessado em modelos que funcionam
        fora do laboratório.
      </p>
      <div class="hero__links">
        <a href="https://github.com/felipetp-ctrl" target="_blank" rel="noopener" class="btn btn--primary">
          GitHub
        </a>
        <a href="https://linkedin.com/in/felipetp" target="_blank" rel="noopener" class="btn btn--outline">
          LinkedIn
        </a>
        <a href="mailto:felipetp@example.com" class="btn btn--ghost">
          Contato
        </a>
      </div>
    </div>
  </section>

  <!-- ── Projects ── -->
  <section class="projects-section" id="projects">
    <div class="container--wide">
      <div class="section-header">
        <span class="section-title">Projetos</span>
        <span class="section-count">{projects.length} trabalhos</span>
      </div>

      <div class="projects-grid">
        {projects.map((project, i) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            technologies={project.data.technologies}
            mainResult={project.data.mainResult}
            date={project.data.date}
            slug={project.id}
            github={project.data.github}
            paper={project.data.paper}
            demo={project.data.demo}
            status={project.data.status}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── Commit Heatmap ── -->
  <CommitHeatmap username="felipetp-ctrl" />
</BaseLayout>
