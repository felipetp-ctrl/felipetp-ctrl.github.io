---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import CommitHeatmap from '../../components/CommitHeatmap.astro';
import ModelZoo from '../../components/ModelZoo.astro';
import PaperHighlight from '../../components/PaperHighlight.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [{ params: { locale: 'pt' } }, { params: { locale: 'en' } }];
}

const { locale } = Astro.params as { locale: 'pt' | 'en' };

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const allHighlights = await getCollection('highlights');
const activeHighlight = allHighlights.filter(h => h.data.active).sort((a, b) => b.data.date.localeCompare(a.data.date))[0];
const allTechs = new Set(projects.flatMap(p => p.data.technologies));

const stats = {
  total: projects.length,
  techs: allTechs.size,
  completed: projects.filter(p => p.data.status === 'completed' || p.data.status === 'published').length,
  inProgress: projects.filter(p => p.data.status === 'in-progress').length,
};

const techGroups = [
  { labelPt: 'Linguagens',          labelEn: 'Languages',          techs: ['Python'] },
  { labelPt: 'Frameworks ML',       labelEn: 'ML Frameworks',      techs: ['PyTorch', 'PyTorch Geometric', 'TensorFlow', 'Keras', 'scikit-learn'] },
  { labelPt: 'LLMs & RAG',          labelEn: 'LLMs & RAG',         techs: ['LlamaIndex', 'Google Gemini 2.5 Flash', 'RAG', 'ReAct'] },
  { labelPt: 'Arquiteturas',        labelEn: 'Architectures',      techs: ['EdgeConv', 'SimCLR'] },
  { labelPt: 'Otimizadores',        labelEn: 'Optimizers',         techs: ['AdamW', 'NT-Xent'] },
  { labelPt: 'Dados & Análise',     labelEn: 'Data & Analysis',    techs: ['Pandas', 'NumPy', 'Matplotlib', 'statsmodels', 'TUDatasets', 'HDF5'] },
  { labelPt: 'Ferramentas',         labelEn: 'Tools',              techs: ['Jupyter Notebook', 'Streamlit', 'Docker'] },
].map(g => ({ ...g, techs: g.techs.filter(t => allTechs.has(t)) }))
 .filter(g => g.techs.length > 0);
---

<BaseLayout
  title="Felipe Tomé Pereira — Machine Learning Research Portfolio"
  description="Student passionate about machine learning, statistics, and databases. Reimplementing papers, exploring datasets, and building pipelines from scratch."
  ogImage={`/og/${locale}/index.png`}
  locale={locale}
>
  <!-- ── Hero ── -->
  <section class="hero">
    <div class="container--wide">
      <p class="hero__label hero--anim-1" data-i18n="hero.label">// portfólio de pesquisa</p>
      <h1 class="hero__name hero--anim-2">Felipe Tomé Pereira</h1>
      <p class="hero__role hero--anim-3">Data Science Enthusiast</p>
      <p class="hero__bio hero--anim-4" data-i18n="hero.bio">
        Estudante apaixonado por machine learning, estatística e bancos de dados.
        Busco aprender e aprofundar continuamente nesses temas, seja reimplementando
        papers, explorando datasets ou construindo pipelines do zero. Cada projeto
        é uma oportunidade de entender melhor como os dados se transformam em
        conhecimento.
      </p>
      <div class="hero__links hero--anim-5">
        <a href="https://github.com/felipetp-ctrl" target="_blank" rel="noopener" class="btn btn--primary">
          GitHub
        </a>
        <a href="https://linkedin.com/in/felipetpereira" target="_blank" rel="noopener" class="btn btn--outline">
          LinkedIn
        </a>
        <a href="mailto:felipetpereira1@gmail.com" class="btn btn--ghost" data-i18n="hero.contact">
          Contato
        </a>
      </div>
    </div>
  </section>

  <!-- ── Projects ── -->
  <section class="projects-section" id="projects">
    <div class="container--wide">
      <div class="section-header">
        <div style="display:flex;align-items:baseline;gap:1rem">
          <span class="section-title" data-i18n="projects.title">Projetos</span>
          <span class="section-count">{projects.length} <span data-i18n="projects.works">trabalhos</span></span>
        </div>
        <div class="view-toggle" role="group" aria-label="View mode">
          <button class="view-toggle__btn view-toggle__btn--active" data-view="grid" aria-label="Grid view">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true">
              <rect x="0" y="0" width="6" height="6"/><rect x="8" y="0" width="6" height="6"/>
              <rect x="0" y="8" width="6" height="6"/><rect x="8" y="8" width="6" height="6"/>
            </svg>
          </button>
          <button class="view-toggle__btn" data-view="timeline" aria-label="Timeline view">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true">
              <rect x="4" y="0" width="10" height="2"/><rect x="4" y="6" width="10" height="2"/>
              <rect x="4" y="12" width="10" height="2"/>
              <circle cx="1" cy="1" r="1.5"/><circle cx="1" cy="7" r="1.5"/><circle cx="1" cy="13" r="1.5"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- ── Stats dashboard ── -->
      <div class="project-stats">
        <div class="project-stat">
          <span class="project-stat__value">{stats.total}</span>
          <span class="project-stat__label" data-i18n-pt="projetos" data-i18n-en="projects">projetos</span>
        </div>
        <div class="project-stat">
          <span class="project-stat__value">{stats.techs}</span>
          <span class="project-stat__label" data-i18n-pt="tecnologias" data-i18n-en="technologies">tecnologias</span>
        </div>
        <div class="project-stat">
          <span class="project-stat__value">{stats.completed}</span>
          <span class="project-stat__label" data-i18n-pt="concluídos" data-i18n-en="completed">concluídos</span>
        </div>
        {stats.inProgress > 0 && (
          <div class="project-stat">
            <span class="project-stat__value project-stat__value--active">{stats.inProgress}</span>
            <span class="project-stat__label" data-i18n-pt="em andamento" data-i18n-en="in progress">em andamento</span>
          </div>
        )}
      </div>

      <!-- ── Advanced filter bar ── -->
      <div class="advanced-filter" id="advanced-filter">
        <input
          id="project-text-filter"
          class="advanced-filter__input"
          type="search"
          data-placeholder-pt="Buscar projetos..."
          data-placeholder-en="Search projects..."
          placeholder="Buscar projetos..."
          aria-label="Buscar projetos"
        />
        <label class="advanced-filter__checkbox-label">
          <input type="checkbox" id="filter-completed" value="completed" />
          <span data-i18n-pt="Concluídos" data-i18n-en="Completed">Concluídos</span>
        </label>
        <label class="advanced-filter__checkbox-label">
          <input type="checkbox" id="filter-inprogress" value="in-progress" />
          <span data-i18n-pt="Em andamento" data-i18n-en="In progress">Em andamento</span>
        </label>
        <label class="advanced-filter__checkbox-label">
          <input type="checkbox" id="filter-study" value="study" />
          <span data-i18n-pt="Estudos" data-i18n-en="Studies">Estudos</span>
        </label>
        <span class="advanced-filter__count" id="filter-count"></span>
        <button id="filter-reset" class="btn btn--ghost" style="font-size:0.72rem; padding:0.25rem 0.6rem; display:none;"
          data-i18n-pt="Limpar" data-i18n-en="Clear">Limpar</button>
      </div>

      <!-- Grid view -->
      <div class="projects-grid" id="view-grid">
        {projects.map((project, i) => (
          <ProjectCard
            title={project.data.title}
            titleEn={project.data.titleEn}
            description={project.data.description}
            descriptionEn={project.data.descriptionEn}
            technologies={project.data.technologies}
            mainResult={project.data.mainResult}
            mainResultEn={project.data.mainResultEn}
            date={project.data.date}
            slug={project.id}
            github={project.data.github}
            paper={project.data.paper}
            demo={project.data.demo}
            status={project.data.status}
            study={project.data.study}
            index={i}
            locale={locale}
          />
        ))}
      </div>

      <!-- Timeline view -->
      <div class="projects-timeline" id="view-timeline" style="display:none">
        {[...projects].sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).map((project) => (
          <div class="timeline-project">
            <div class="timeline-project__date">
              <span class="timeline-project__year">{project.data.date.split('-')[0]}</span>
              <span class="timeline-project__month">{project.data.date.split('-').slice(0,2).join('-')}</span>
            </div>
            <div class="timeline-project__connector">
              <div class="timeline-project__dot"></div>
              <div class="timeline-project__line"></div>
            </div>
            <div class="timeline-project__content">
              <a href={`/${locale}/projects/${project.id}`} class="timeline-project__title"
                data-i18n-pt={project.data.title}
                data-i18n-en={project.data.titleEn || project.data.title}
              >{project.data.title}</a>
              <p class="timeline-project__desc"
                data-i18n-pt={project.data.description}
                data-i18n-en={project.data.descriptionEn || project.data.description}
              >{project.data.description}</p>
              <div class="tags" style="margin-top:0.4rem">
                {project.data.technologies.slice(0,4).map((t: string) => <span class="tag">{t}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── ML Model Zoo ── -->
  <ModelZoo locale={locale} />

  <!-- ── Commit Heatmap ── -->
  <CommitHeatmap username="felipetp-ctrl" />

  <!-- ── Paper of the Week ── -->
  {activeHighlight && (
    <div class="container--wide" style="padding: 2rem 1.5rem 0;">
      <PaperHighlight
        title={activeHighlight.data.title}
        titleEn={activeHighlight.data.titleEn}
        authors={activeHighlight.data.authors}
        url={activeHighlight.data.url}
        summary={activeHighlight.data.summary}
        summaryEn={activeHighlight.data.summaryEn}
        date={activeHighlight.data.date}
      />
    </div>
  )}
</BaseLayout>

<script is:inline>
  // ── Advanced filter logic ──
  function applyFilters() {
    var text = (document.getElementById('project-text-filter')?.value || '').toLowerCase().trim();
    var completedCb = document.getElementById('filter-completed');
    var inprogressCb = document.getElementById('filter-inprogress');
    var studyCb = document.getElementById('filter-study');
    var filterCompleted = completedCb?.checked;
    var filterInprogress = inprogressCb?.checked;
    var filterStudy = studyCb?.checked;
    var anyStatus = filterCompleted || filterInprogress;
    var anyCheck = anyStatus || filterStudy;
    var lang = window.__i18n ? window.__i18n.getLang() : 'pt';

    var cards = document.querySelectorAll('.project-card[data-filter-tags]');
    var visible = 0;
    cards.forEach(function (card) {
      var tags = (card.dataset.filterTags || '').toLowerCase();
      var status = card.dataset.filterStatus || '';
      var type = card.dataset.filterType || '';
      var titleEl = card.querySelector('.project-card__title');
      var descEl = card.querySelector('.project-card__desc');
      var title = (lang === 'en' ? (titleEl?.dataset.i18nEn || titleEl?.textContent) : titleEl?.textContent || '').toLowerCase();
      var desc = (lang === 'en' ? (descEl?.dataset.i18nEn || descEl?.textContent) : descEl?.textContent || '').toLowerCase();

      var textMatch = !text || title.includes(text) || desc.includes(text) || tags.includes(text);

      var statusMatch = true;
      if (anyStatus) {
        statusMatch = false;
        if (filterCompleted && (status === 'completed' || status === 'published')) statusMatch = true;
        if (filterInprogress && status === 'in-progress') statusMatch = true;
      }
      var typeMatch = !filterStudy || type === 'study';

      var show = textMatch && statusMatch && typeMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    var countEl = document.getElementById('filter-count');
    var resetBtn = document.getElementById('filter-reset');
    var isFiltering = text || anyCheck;
    if (countEl) countEl.textContent = isFiltering ? visible + (lang === 'en' ? ' shown' : ' exibidos') : '';
    if (resetBtn) resetBtn.style.display = isFiltering ? '' : 'none';
  }

  document.addEventListener('input', function (e) {
    if (e.target.id === 'project-text-filter') applyFilters();
  });
  document.addEventListener('change', function (e) {
    if (['filter-completed','filter-inprogress','filter-study'].includes(e.target.id)) applyFilters();
  });
  document.addEventListener('click', function (e) {
    if (e.target.id === 'filter-reset') {
      var tf = document.getElementById('project-text-filter');
      if (tf) tf.value = '';
      ['filter-completed','filter-inprogress','filter-study'].forEach(function (id) {
        var cb = document.getElementById(id);
        if (cb) cb.checked = false;
      });
      applyFilters();
    }
  });
  document.addEventListener('astro:page-load', function () {
    // update placeholder on lang change
    var lang = window.__i18n ? window.__i18n.getLang() : 'pt';
    var tf = document.getElementById('project-text-filter');
    if (tf) tf.placeholder = lang === 'en' ? 'Search projects...' : 'Buscar projetos...';
    applyFilters();
  });

  // ── View toggle (grid / timeline) ──
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.view-toggle__btn');
    if (!btn) return;
    var view = btn.dataset.view;
    document.querySelectorAll('.view-toggle__btn').forEach(function (b) {
      b.classList.toggle('view-toggle__btn--active', b.dataset.view === view);
    });
    var grid = document.getElementById('view-grid');
    var timeline = document.getElementById('view-timeline');
    if (grid) grid.style.display = view === 'grid' ? '' : 'none';
    if (timeline) timeline.style.display = view === 'timeline' ? '' : 'none';
    var advFilter = document.getElementById('advanced-filter');
    if (advFilter) advFilter.style.display = view === 'timeline' ? 'none' : '';
  });
</script>
